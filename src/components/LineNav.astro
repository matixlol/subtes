---
import { diagramLines } from "../lib/line-data";

interface Props {
	class?: string;
	currentCode?: string | null;
}

const { class: className = "", currentCode = null } = Astro.props;

const lines = diagramLines.map((line) => ({
	code: line.code,
	color: line.color,
	ink: line.ink,
	nombreLinea: line.nombreLinea,
	path: `/linea/${line.code}`,
}));
---

<nav
	aria-label="Cambiar línea"
	transition:name="line-nav"
	class={`mx-auto grid w-full max-w-[430px] grid-cols-6 gap-1.5 px-1.5 py-1.5 ${className}`}
>
	{
		lines.map((line) => (
			<a
				href={line.path}
				aria-label={`Ir a ${line.nombreLinea}`}
				aria-current={line.code === currentCode ? "page" : undefined}
				data-active={line.code === currentCode ? "true" : "false"}
				data-line-link={line.code}
				data-astro-prefetch
				class="line-switch shrink-0"
				style={`--line-button-color: ${line.color}; --line-button-ink: ${line.ink};`}
			>
				<span class="line-switch__top">
					<span class="line-switch__label">{line.code}</span>
				</span>
			</a>
		))
	}
</nav>

<style>
	.line-switch {
		--button-outline-color: #2f241d;
		display: block;
		width: 100%;
		border: 0;
		border-radius: 12px;
		background: var(--button-outline-color);
		padding: 0;
		font: inherit;
		color: inherit;
		text-decoration: none;
		cursor: pointer;
	}

	.line-switch__top {
		display: flex;
		width: 100%;
		aspect-ratio: 1;
		align-items: center;
		justify-content: center;
		border: 2px solid var(--button-outline-color);
		border-radius: 12px;
		background: var(--line-button-color);
		color: var(--line-button-ink);
		transform: translateY(-0.2em);
		transition:
			transform 100ms ease,
			filter 100ms ease;
	}

	.line-switch__label {
		font-size: clamp(1.25rem, 4.4vw, 2rem);
		line-height: 1;
		font-weight: 700;
		letter-spacing: -0.06em;
	}

	.line-switch:hover .line-switch__top,
	.line-switch:focus-visible .line-switch__top {
		transform: translateY(-0.33em);
	}

	.line-switch:active .line-switch__top,
	.line-switch[data-active="true"] .line-switch__top {
		transform: translateY(0);
	}

	.line-switch[data-active="true"] .line-switch__top {
		filter: saturate(1.08);
	}

	.line-switch:focus-visible {
		outline: 0;
	}
</style>
