---
// PostHog analytics snippet with View Transitions support.
// Uses is:inline to prevent Astro from processing the script.
---
<script
    is:inline
    define:vars={{
        apiKey: import.meta.env.PUBLIC_POSTHOG_PROJECT_TOKEN,
        apiHost: import.meta.env.PUBLIC_POSTHOG_HOST,
    }}
>
    if (!window.__posthog_initialized) {
        window.__posthog_initialized = true;
        !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="capture identify alias people.set people.set_once set_config register register_once unregister opt_out_capturing has_opted_out_capturing opt_in_capturing reset isFeatureEnabled onFeatureFlags getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures getActiveMatchingSurveys getSurveys getNextSurveyStep onSessionId".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
        posthog.init(apiKey || "", {
            api_host: apiHost || "",
            defaults: "2026-01-30",
            capture_pageview: "history_change",
        });
    }

    if (!window.__subte_scroll_depth_bound) {
        window.__subte_scroll_depth_bound = true;

        const scrollState = {
            maxPercentage: 0,
            maxPixels: 0,
            pageUrl: window.location.href,
        };

        const getPageHeight = () =>
            Math.max(
                document.body?.offsetHeight ?? 0,
                document.body?.scrollHeight ?? 0,
                document.documentElement?.offsetHeight ?? 0,
                document.documentElement?.scrollHeight ?? 0,
                1,
            );

        const getLastPixels = () => window.innerHeight + window.pageYOffset;
        const getLastPercentage = () =>
            Math.min(1, getLastPixels() / getPageHeight());

        const resetScrollDepth = () => {
            scrollState.maxPercentage = 0;
            scrollState.maxPixels = 0;
            scrollState.pageUrl = window.location.href;
        };

        const updateScrollDepth = () => {
            const lastPercentage = getLastPercentage();
            const lastPixels = getLastPixels();

            if (lastPercentage > scrollState.maxPercentage) {
                scrollState.maxPercentage = lastPercentage;
            }

            if (lastPixels > scrollState.maxPixels) {
                scrollState.maxPixels = lastPixels;
            }
        };

        const captureScrollDepth = (trigger) => {
            const pageUrl = scrollState.pageUrl;
            const pagePath = new URL(pageUrl).pathname;

            window.posthog?.capture("left_page", {
                trigger,
                page_url: pageUrl,
                page_path: pagePath,
                max_scroll_percentage: scrollState.maxPercentage,
                max_scroll_pixels: scrollState.maxPixels,
                last_scroll_percentage: getLastPercentage(),
                last_scroll_pixels: getLastPixels(),
                scrolled: scrollState.maxPixels > 0,
            });
        };

        window.addEventListener("scroll", updateScrollDepth, { passive: true });
        window.addEventListener("pagehide", () => {
            captureScrollDepth("pagehide");
        });
        window.addEventListener("pageshow", () => {
            resetScrollDepth();
        });
        document.addEventListener("astro:before-swap", () => {
            captureScrollDepth("route_change");
        });
        document.addEventListener("astro:page-load", () => {
            resetScrollDepth();
        });

        resetScrollDepth();
    }
</script>
