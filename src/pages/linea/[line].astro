---
import { ClientRouter } from "astro:transitions";
import FrequencyChart from "../../components/FrequencyChart.astro";
import LineNav from "../../components/LineNav.astro";
import PostHog from "../../components/posthog.astro";
import "../../styles/global.css";
import {
    frequencyChangeByLine,
    getFrequencySeriesForLineCode,
} from "../../lib/frequency-data";
import {
    diagramLines,
    formatDeviceName,
    getAccessibilityStateLabel,
    getDeviceStatusLabel,
    overviewMeta,
} from "../../lib/line-data";

export function getStaticPaths() {
    return diagramLines.map((line) => ({
        params: { line: line.code },
    }));
}

const formatTimestamp = (value: string) => {
    if (!value) return "sin fecha";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return value;

    return new Intl.DateTimeFormat("es-AR", {
        dateStyle: "short",
        timeStyle: "short",
    }).format(date);
};

const formatDayCount = (value: number) =>
    `${value} ${value === 1 ? "día" : "días"}`;

const getStatusFillClass = (state: string) => {
    if (state === "full") return "bg-[var(--heat-0)]";
    if (state === "partial") return "bg-[var(--heat-2)]";
    if (state === "off-hours") return "bg-[#f1dfaa]";
    if (state === "blocked") return "bg-[var(--heat-4)]";
    return "bg-[var(--surface)]";
};

const withAlpha = (hex: string, alpha: number) => {
    const normalized = hex.replace("#", "");
    if (normalized.length !== 6) return hex;

    const red = Number.parseInt(normalized.slice(0, 2), 16);
    const green = Number.parseInt(normalized.slice(2, 4), 16);
    const blue = Number.parseInt(normalized.slice(4, 6), 16);

    return `rgba(${red}, ${green}, ${blue}, ${alpha})`;
};

const currentCode =
    `${Astro.params.line ?? diagramLines[0]?.code ?? "A"}`.toUpperCase();
const frequencyChangeByLineMap = new Map(
    frequencyChangeByLine.map((line) => [line.series.label, line]),
);
const lines = diagramLines.map((line, index, all) => ({
    ...line,
    path: `/linea/${line.code}`,
    frequencySeries: getFrequencySeriesForLineCode(line.code),
    frequencyChange: frequencyChangeByLineMap.get(line.nombreLinea) ?? null,
    position: index + 1,
    previous: all[index - 1]
        ? {
              code: all[index - 1].code,
              path: `/linea/${all[index - 1].code}`,
          }
        : null,
    next: all[index + 1]
        ? {
              code: all[index + 1].code,
              path: `/linea/${all[index + 1].code}`,
          }
        : null,
}));

const initialIndex = Math.max(
    0,
    lines.findIndex((line) => line.code === currentCode),
);
const initialLine = lines[initialIndex] ?? lines[0];

const getStationTooltipId = (lineCode: string, stationOrder: number) =>
    `line-tooltip-${lineCode}-${stationOrder}`;
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{`Línea ${initialLine.code} · Accesibilidad`}</title>
        <ClientRouter />
        <PostHog />
    </head>
    <body
        class="min-h-screen transition-colors duration-500"
        style={`background-color: ${initialLine.color};`}
    >
        <div class="fixed inset-x-0 top-0 z-40 px-3 pt-3">
            <LineNav mode="buttons" currentCode={initialLine.code} />
        </div>

        <main
            data-line-scroller
            data-initial-line={initialLine.code}
            class="min-h-screen overflow-x-auto snap-x snap-mandatory overscroll-x-none [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
        >
            <div class="flex items-start">
                {
                    lines.map((line, lineIndex) => (
                        <section
                            id={`linea-${line.code}`}
                            data-line-slide
                            data-line-code={line.code}
                            data-line-color={line.color}
                            data-line-path={line.path}
                            data-line-position={line.position}
                            data-active={
                                line.code === initialLine.code
                                    ? "true"
                                    : "false"
                            }
                            class="min-h-screen w-screen shrink-0 snap-center px-4 pb-8 pt-24 [scroll-snap-stop:always] sm:pt-26"
                            style={`color: ${line.ink}; --line-border: ${withAlpha(line.ink, 0.22)}; --line-border-strong: ${withAlpha(line.ink, 0.42)}; --line-muted: ${withAlpha(line.ink, 0.76)};`}
                        >
                            <div class="mx-auto w-full max-w-6xl">
                                <section
                                    class="reveal mt-5 px-2 py-2 text-inherit"
                                    style={`--stagger: 120ms;`}
                                >
                                    <h2
                                        class="text-4xl leading-none font-semibold tracking-[-0.06em] text-inherit sm:text-6xl"
                                    >
                                        Accesibilidad
                                    </h2>

                                    <div class="mt-8 max-w-[460px]">
                                        <div class="flex items-center justify-between gap-3 pb-2">
                                            <div>
                                                <h3 class="m-0 text-[1.08rem] leading-[1.1] font-semibold">
                                                    Estaciones
                                                </h3>
                                            </div>
                                        </div>

                                        <ol class="relative mt-4 ml-0 list-none pl-0">
                                            <span
                                                class="pointer-events-none absolute bottom-4 left-[18px] top-4 w-[3px] rounded-full"
                                                style={`background-color: ${withAlpha(line.ink, 0.28)};`}
                                                aria-hidden="true"
                                            />
                                            {line.stations.map(
                                                (station, stationIndex) => (
                                                    <li
                                                        class="station-item reveal relative py-3 pl-12"
                                                        style={`--stagger: ${160 + stationIndex * 26}ms;`}
                                                    >
                                                        <button
                                                            type="button"
                                                            class="flex w-full items-start justify-between gap-3 rounded-[10px] text-left text-inherit outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--line-border-strong)]"
                                                            title={`${line.nombreLinea} · ${station.nombreEstacion}`}
                                                            aria-label={`${line.nombreLinea} · ${station.nombreEstacion}`}
                                                            data-station-tooltip={getStationTooltipId(
                                                                line.code,
                                                                station.stationOrder,
                                                            )}
                                                        >
                                                            <span
                                                                class={`pointer-events-none absolute left-[10px] top-[20px] z-10 block h-[18px] w-[18px] rounded-full border-[2px] ${getStatusFillClass(
                                                                    station.state,
                                                                )}`}
                                                                style={`border-color: ${line.ink};`}
                                                            />
                                                            <span class="min-w-0 flex-1">
                                                                <span class="block text-[1.02rem] leading-[1.15] font-semibold">
                                                                    {
                                                                        station.nombreEstacion
                                                                    }
                                                                </span>
                                                                <span class="mt-1 block text-[0.86rem] leading-[1.25] text-[color:var(--line-muted)]">
                                                                    {station.accessibility
                                                                        ? `${getAccessibilityStateLabel(
                                                                              station.accessibility,
                                                                          )} · ${station.accessibility.funcionando}/${station.accessibility.total} equipos`
                                                                        : "Sin ascensores ni escaleras registradas"}
                                                                </span>
                                                            </span>
                                                            {station.history && (
                                                                <span class="whitespace-nowrap pt-0.5 text-[0.8rem] font-medium text-[color:var(--line-muted)]">
                                                                    {
                                                                        station
                                                                            .history
                                                                            .daysWithAnyFailure
                                                                    }
                                                                    d
                                                                </span>
                                                            )}
                                                        </button>

                                                        <template
                                                            id={getStationTooltipId(
                                                                line.code,
                                                                station.stationOrder,
                                                            )}
                                                        >
                                                            <div class="w-[300px] rounded-[10px] border border-[var(--border)] bg-[#fffdf8] px-3 py-3 text-left text-[var(--text)] shadow-[0_10px_24px_rgba(47,36,29,0.16)]">
                                                                <p class="m-0 text-[0.72rem] text-[var(--muted)]">
                                                                    {
                                                                        line.nombreLinea
                                                                    }
                                                                </p>
                                                                <p class="mt-1 text-[0.96rem] font-semibold leading-tight">
                                                                    {
                                                                        station.nombreEstacion
                                                                    }
                                                                </p>

                                                                {station.accessibility ? (
                                                                    <>
                                                                        <p class="mt-1 text-[0.8rem] leading-[1.3] text-[var(--muted)]">
                                                                            {getAccessibilityStateLabel(
                                                                                station.accessibility,
                                                                            )}{" "}
                                                                            ·{" "}
                                                                            {
                                                                                station
                                                                                    .accessibility
                                                                                    .funcionando
                                                                            }
                                                                            /
                                                                            {
                                                                                station
                                                                                    .accessibility
                                                                                    .total
                                                                            }{" "}
                                                                            equipos
                                                                            funcionando
                                                                        </p>

                                                                        <ul class="m-0 mt-2 list-none space-y-1 border-t border-[#eee7df] pt-2 pl-0 text-[0.8rem] leading-[1.3]">
                                                                            {station.accessibility.devices.map(
                                                                                (
                                                                                    device,
                                                                                ) => (
                                                                                    <li class="flex items-start justify-between gap-3">
                                                                                        <span>
                                                                                            {formatDeviceName(
                                                                                                device,
                                                                                            )}
                                                                                        </span>
                                                                                        <span class="whitespace-nowrap text-[var(--muted)]">
                                                                                            {getDeviceStatusLabel(
                                                                                                device.estado,
                                                                                            )}
                                                                                        </span>
                                                                                    </li>
                                                                                ),
                                                                            )}
                                                                        </ul>

                                                                        <div class="mt-2 border-t border-[#eee7df] pt-2 text-[0.76rem] leading-[1.35] text-[var(--muted)]">
                                                                            {station.history && (
                                                                                <span class="block">
                                                                                    Últimos{" "}
                                                                                    {
                                                                                        station
                                                                                            .history
                                                                                            .windowDays
                                                                                    }{" "}
                                                                                    días:{" "}
                                                                                    {formatDayCount(
                                                                                        station
                                                                                            .history
                                                                                            .daysWithAnyFailure,
                                                                                    )}{" "}
                                                                                    con
                                                                                    fallas
                                                                                </span>
                                                                            )}
                                                                            <span class="block">
                                                                                Actualizado:{" "}
                                                                                {formatTimestamp(
                                                                                    station
                                                                                        .accessibility
                                                                                        .ultimaActualizacion,
                                                                                )}
                                                                            </span>
                                                                        </div>
                                                                    </>
                                                                ) : (
                                                                    <p class="mt-2 text-[0.8rem] leading-[1.35] text-[var(--muted)]">
                                                                        Esta
                                                                        estación no
                                                                        tiene
                                                                        ascensores
                                                                        ni escaleras
                                                                        registradas
                                                                        en el
                                                                        dataset
                                                                        actual.
                                                                    </p>
                                                                )}
                                                            </div>
                                                        </template>
                                                    </li>
                                                ),
                                            )}
                                        </ol>
                                    </div>
                                </section>

                                <section
                                    class="reveal mt-14 px-2 py-2 text-inherit"
                                    style={`--stagger: 60ms;`}
                                >
                                    <h2
                                        class="text-4xl leading-none font-semibold tracking-[-0.06em] text-inherit sm:text-6xl"
                                    >
                                        Frecuencia
                                    </h2>

                                    {line.frequencyChange && (
                                        <p
                                            class="mt-6 max-w-3xl text-pretty text-lg leading-7 text-[color:var(--line-muted)] sm:text-xl"
                                        >
                                            <span
                                                class="font-semibold text-inherit"
                                                >{line.frequencyChange.changeLabel}</span
                                            >{" "}
                                            entre{" "}
                                            {
                                                line.frequencyChange
                                                    .firstPeriodLabel
                                            }
                                            {" "}y{" "}
                                            {
                                                line.frequencyChange
                                                    .latestPeriodLabel
                                            }
                                            . Pasó de{" "}
                                            {
                                                line.frequencyChange
                                                    .firstValueLabel
                                            }{" "}
                                            a{" "}
                                            {
                                                line.frequencyChange
                                                    .latestValueLabel
                                            }
                                            .
                                        </p>
                                    )}

                                    {line.frequencySeries && (
                                        <div
                                            class="mt-8 overflow-hidden rounded-[10px] border"
                                            style={`border-color: ${withAlpha(line.ink, 0.24)};`}
                                        >
                                            <FrequencyChart
                                                series={[
                                                    line.frequencySeries,
                                                ]}
                                                showEndLabels={false}
                                                title={`Frecuencia mensual de la ${line.nombreLinea}`}
                                                description={`Serie mensual del intervalo promedio entre trenes de la ${line.nombreLinea}. Valores más bajos indican mejor frecuencia.`}
                                            />
                                        </div>
                                    )}
                                </section>
                            </div>
                        </section>
                    ))
                }
            </div>
        </main>

        <style is:global>
            [data-line-scroller][data-ready="true"] [data-line-slide] .reveal {
                opacity: 0;
                transform: translateY(18px) scale(0.985);
                transition:
                    opacity 320ms ease,
                    transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
                transition-delay: var(--stagger, 0ms);
            }

            [data-line-scroller][data-ready="true"]
                [data-line-slide][data-active="true"]
                .reveal {
                opacity: 1;
                transform: translateY(0) scale(1);
            }

            [data-line-scroller][data-ready="true"]
                [data-line-slide][data-active="false"]
                .station-item {
                opacity: 0.62;
            }
        </style>

        <script is:inline>
            (() => {
                const scroller = document.querySelector("[data-line-scroller]");
                if (!(scroller instanceof HTMLElement)) return;

                const slides = Array.from(
                    scroller.querySelectorAll("[data-line-slide]"),
                ).filter((slide) => slide instanceof HTMLElement);
                if (slides.length === 0) return;
                const lineButtons = Array.from(
                    document.querySelectorAll("[data-line-button]"),
                ).filter((button) => button instanceof HTMLButtonElement);

                const tooltip = document.createElement("div");
                tooltip.className =
                    "pointer-events-none fixed z-50 hidden max-w-[calc(100vw-16px)]";
                document.body.appendChild(tooltip);

                let activeButton = null;
                let activeCode =
                    scroller.dataset.initialLine ?? slides[0].dataset.lineCode;
                let settleFrame = 0;
                let settleTimeout = 0;
                let pendingCode = null;
                let scrollAnimationFrame = 0;
                let isProgrammaticAnimating = false;

                const setBodyColor = (slide) => {
                    document.body.style.backgroundColor =
                        slide.dataset.lineColor ?? "";
                };

                const setActiveButton = (code) => {
                    lineButtons.forEach((button) => {
                        const isActive = button.dataset.lineButton === code;
                        button.dataset.active = isActive ? "true" : "false";
                        button.setAttribute(
                            "aria-pressed",
                            isActive ? "true" : "false",
                        );
                    });
                };

                const setVisualActiveSlide = (slide) => {
                    slides.forEach((candidate) => {
                        candidate.dataset.active =
                            candidate === slide ? "true" : "false";
                    });

                    setBodyColor(slide);
                };

                const commitActiveSlide = (slide, updateHistory = true) => {
                    const code = slide.dataset.lineCode;
                    if (!code) return;

                    setVisualActiveSlide(slide);
                    setActiveButton(code);

                    if (updateHistory && code !== activeCode) {
                        history.replaceState(
                            {},
                            "",
                            slide.dataset.linePath ?? `/linea/${code}`,
                        );
                        document.title = `Línea ${code} · Accesibilidad`;
                        window.posthog?.capture('line_viewed', { line_code: code });
                    }

                    activeCode = code;
                    pendingCode = null;
                };

                const getNearestSlide = () =>
                    slides.reduce((closest, slide) => {
                        if (!closest) return slide;

                        return Math.abs(
                            scroller.scrollLeft - slide.offsetLeft,
                        ) < Math.abs(scroller.scrollLeft - closest.offsetLeft)
                            ? slide
                            : closest;
                    }, null);

                const scheduleSettledCommit = () => {
                    window.clearTimeout(settleTimeout);
                    cancelAnimationFrame(settleFrame);

                    settleTimeout = window.setTimeout(() => {
                        settleFrame = requestAnimationFrame(() => {
                            const settledSlide = getNearestSlide();
                            if (settledSlide) {
                                commitActiveSlide(settledSlide, true);
                            }
                        });
                    }, 120);
                };

                const stopProgrammaticScroll = () => {
                    if (scrollAnimationFrame) {
                        cancelAnimationFrame(scrollAnimationFrame);
                        scrollAnimationFrame = 0;
                    }

                    isProgrammaticAnimating = false;
                    pendingCode = null;
                };

                const animateScrollerTo = (targetLeft, onComplete) => {
                    stopProgrammaticScroll();

                    const startLeft = scroller.scrollLeft;
                    const distance = targetLeft - startLeft;
                    if (Math.abs(distance) < 1) {
                        scroller.scrollLeft = targetLeft;
                        onComplete();
                        return;
                    }

                    const startTime = performance.now();
                    const duration = 360;
                    isProgrammaticAnimating = true;

                    const step = (now) => {
                        const elapsed = now - startTime;
                        const progress = Math.min(elapsed / duration, 1);
                        const eased =
                            progress < 0.5
                                ? 4 * progress * progress * progress
                                : 1 - Math.pow(-2 * progress + 2, 3) / 2;

                        scroller.scrollLeft = startLeft + distance * eased;

                        if (progress < 1) {
                            scrollAnimationFrame = requestAnimationFrame(step);
                            return;
                        }

                        scroller.scrollLeft = targetLeft;
                        scrollAnimationFrame = 0;
                        isProgrammaticAnimating = false;
                        onComplete();
                    };

                    scrollAnimationFrame = requestAnimationFrame(step);
                };

                const scrollToCode = (code, behavior = "smooth") => {
                    const target = slides.find(
                        (slide) => slide.dataset.lineCode === code,
                    );
                    if (!(target instanceof HTMLElement)) return;

                    const shouldAnimate =
                        behavior !== "auto" &&
                        Math.abs(scroller.scrollLeft - target.offsetLeft) >= 1;

                    if (shouldAnimate) {
                        pendingCode = code;
                        setVisualActiveSlide(target);
                        setActiveButton(code);
                        animateScrollerTo(target.offsetLeft, () => {
                            commitActiveSlide(target, true);
                        });
                        return;
                    }

                    stopProgrammaticScroll();
                    scroller.scrollLeft = target.offsetLeft;

                    if (!shouldAnimate) {
                        commitActiveSlide(target, true);
                        return;
                    }
                };

                const scrollViewportToTop = (behavior = "smooth") => {
                    window.scrollTo({ top: 0, left: 0, behavior });
                };

                const positionTooltip = (button) => {
                    const rect = button.getBoundingClientRect();
                    const tooltipRect = tooltip.getBoundingClientRect();
                    const gap = 10;
                    const maxLeft = window.innerWidth - tooltipRect.width - 8;
                    const preferredTop = rect.top - tooltipRect.height - gap;
                    const top =
                        preferredTop >= 8 ? preferredTop : rect.bottom + gap;
                    const left = Math.min(
                        Math.max(
                            rect.left + rect.width / 2 - tooltipRect.width / 2,
                            8,
                        ),
                        Math.max(8, maxLeft),
                    );

                    tooltip.style.top = `${top}px`;
                    tooltip.style.left = `${left}px`;
                };

                const showTooltip = (button) => {
                    const templateId = button.dataset.stationTooltip;
                    if (!templateId) return;

                    const template = document.getElementById(templateId);
                    if (!(template instanceof HTMLTemplateElement)) return;

                    tooltip.innerHTML = template.innerHTML;
                    tooltip.classList.remove("hidden");
                    activeButton = button;
                    positionTooltip(button);

                    const stationName = button.querySelector('.station-name')?.textContent?.trim()
                        ?? button.getAttribute('aria-label') ?? '';
                    const lineCode = button.closest('[data-line-slide]')?.dataset?.lineCode ?? '';
                    window.posthog?.capture('station_tooltip_opened', {
                        station_name: stationName,
                        line_code: lineCode,
                    });
                };

                const hideTooltip = (button) => {
                    if (button && activeButton !== button) return;
                    activeButton = null;
                    tooltip.classList.add("hidden");
                    tooltip.innerHTML = "";
                };

                requestAnimationFrame(() => {
                    scrollToCode(
                        activeCode ?? slides[0].dataset.lineCode,
                        "auto",
                    );
                    scroller.dataset.ready = "true";
                });

                scroller.addEventListener(
                    "scroll",
                    () => {
                        if (isProgrammaticAnimating) return;

                        if (!pendingCode) {
                            const nearestSlide = getNearestSlide();
                            if (nearestSlide) {
                                setVisualActiveSlide(nearestSlide);
                            }
                        }

                        scheduleSettledCommit();
                    },
                    { passive: true },
                );

                scroller.addEventListener("pointerdown", stopProgrammaticScroll, {
                    passive: true,
                });
                scroller.addEventListener("touchstart", stopProgrammaticScroll, {
                    passive: true,
                });
                scroller.addEventListener("wheel", stopProgrammaticScroll, {
                    passive: true,
                });

                document
                    .querySelectorAll("[data-line-link]")
                    .forEach((link) => {
                        link.addEventListener("click", (event) => {
                            if (
                                event.metaKey ||
                                event.ctrlKey ||
                                event.shiftKey ||
                                event.altKey
                            ) {
                                return;
                            }

                            event.preventDefault();
                            scrollViewportToTop("smooth");
                            scrollToCode(link.dataset.lineLink, "smooth");
                        });
                    });

                lineButtons.forEach((button) => {
                    button.addEventListener("click", () => {
                        scrollViewportToTop("smooth");
                        scrollToCode(button.dataset.lineButton, "smooth");
                    });
                });

                document
                    .querySelectorAll("[data-station-tooltip]")
                    .forEach((button) => {
                        button.addEventListener("mouseenter", () =>
                            showTooltip(button),
                        );
                        button.addEventListener("focus", () =>
                            showTooltip(button),
                        );
                        button.addEventListener("mouseleave", () =>
                            hideTooltip(button),
                        );
                        button.addEventListener("blur", () =>
                            hideTooltip(button),
                        );
                    });

                window.addEventListener("resize", () => {
                    if (activeButton) positionTooltip(activeButton);
                });

                document.addEventListener(
                    "scroll",
                    () => {
                        if (activeButton) positionTooltip(activeButton);
                    },
                    true,
                );
            })();
        </script>
    </body>
</html>
