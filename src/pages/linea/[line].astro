---
import { ClientRouter } from "astro:transitions";
import DeviceBadge from "../../components/DeviceBadge.astro";
import FrequencyChart from "../../components/FrequencyChart.astro";
import LineNav from "../../components/LineNav.astro";
import PostHog from "../../components/posthog.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import "../../styles/global.css";
import {
	frequencyChangeByLine,
	getFrequencySeriesForLineCode,
} from "../../lib/frequency-data";
import {
	diagramLines,
	formatDeviceName,
	getAccessibilityStateLabel,
	getDeviceStatusLabel,
} from "../../lib/line-data";

const getStatusFillClass = (state: string) => {
	if (state === "full") return "bg-white";
	if (state === "partial") return "bg-[#d89a4d]";
	if (state === "off-hours") return "bg-[#f1dfaa]";
	if (state === "blocked") return "bg-[#b43b2f]";
	return "bg-[var(--surface)]";
};

const isDeviceAvailable = (status: string) => status === "funcionando";
const withAlpha = (hex: string, alpha: number) => {
	const normalized = hex.replace("#", "");
	if (normalized.length !== 6) return hex;

	const red = Number.parseInt(normalized.slice(0, 2), 16);
	const green = Number.parseInt(normalized.slice(2, 4), 16);
	const blue = Number.parseInt(normalized.slice(4, 6), 16);

	return `rgba(${red}, ${green}, ${blue}, ${alpha})`;
};

const currentCode =
	`${Astro.params.line ?? diagramLines[0]?.code ?? "A"}`.toUpperCase();
const line =
	diagramLines.find((entry) => entry.code === currentCode) ?? diagramLines[0];
const frequencyChangeByLineMap = new Map(
	frequencyChangeByLine.map((entry) => [entry.series.label, entry]),
);
const frequencySeries = getFrequencySeriesForLineCode(line.code);
const frequencyChange = frequencyChangeByLineMap.get(line.nombreLinea) ?? null;
const accessibilityPanelId = `panel-accesibilidad-${line.code.toLowerCase()}`;
const frequencyPanelId = `panel-frecuencia-${line.code.toLowerCase()}`;
const lineSummaryLabel = `${line.totalStations} estaciones, ${line.stationsWithDetail} con equipamiento registrado`;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{`Línea ${line.code} · Subte porteño`}</title>
		<ClientRouter />
		<PostHog />
	</head>
	<body class="min-h-screen bg-[#faf8f5] text-[#1d1a16]">
		<header
			class="px-4 pb-4 pt-4 sm:px-6"
			style={`background-color: ${line.color};`}
		>
			<div class="mx-auto flex w-full max-w-[430px] flex-col gap-3">
				<a
					href="/"
					data-astro-prefetch
					class="inline-flex h-11 w-full items-center justify-center rounded-[10px] border border-[#1d1a16]/12 bg-[#fffdf8] px-4 text-[0.98rem] font-semibold tracking-[-0.02em] text-[#1d1a16] transition-colors duration-150 hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#1d1a16]/15"
				>
					Volver a general
				</a>
				<LineNav currentCode={line.code} class="max-w-none px-0 py-0" />
			</div>
		</header>

		<main class="bg-[#faf8f5] px-5 pb-14 pt-8 sm:px-8 sm:pt-10">
			<div class="mx-auto w-full max-w-[36rem]">
				<header class="space-y-3">
					<div class="space-y-1">
						<h1
							class="text-4xl leading-none font-semibold tracking-[-0.06em] text-[#1b1816] sm:text-5xl"
						>
							Línea {line.code}
						</h1>
						<p class="text-sm leading-6 text-[#544b43] sm:text-base">
							{lineSummaryLabel}
						</p>
					</div>
				</header>

				<div
					data-line-tabs
					data-current-tab="accesibilidad"
					class="mt-8"
					style={`--tab-index: 0; --tab-active-ink: ${line.ink};`}
				>
					<div
						role="tablist"
						aria-label={`Secciones de la línea ${line.code}`}
						class="relative grid grid-cols-2 rounded-[10px] border border-[#d8d0c7] bg-[#efe9e1] p-1"
					>
						<span
							aria-hidden="true"
							class="absolute inset-y-1 left-1 rounded-[8px] shadow-[0_1px_0_rgba(255,255,255,0.14)] transition-transform duration-200 ease-out"
							style={`width: calc(50% - 0.25rem); transform: translateX(calc(var(--tab-index, 0) * 100%)); background-color: ${line.color};`}
						></span>
						<button
							id={`tab-accesibilidad-${line.code.toLowerCase()}`}
							type="button"
							role="tab"
							aria-controls={accessibilityPanelId}
							aria-selected="true"
							data-tab-trigger="accesibilidad"
							data-active="true"
							class="relative z-10 flex min-h-11 items-center justify-center rounded-[8px] px-4 text-[0.95rem] font-semibold tracking-[-0.02em] transition-colors duration-150 focus-visible:outline-none"
						>
							Accesibilidad
						</button>
						<button
							id={`tab-frecuencia-${line.code.toLowerCase()}`}
							type="button"
							role="tab"
							aria-controls={frequencyPanelId}
							aria-selected="false"
							data-tab-trigger="frecuencia"
							data-active="false"
							class="relative z-10 flex min-h-11 items-center justify-center rounded-[8px] px-4 text-[0.95rem] font-semibold tracking-[-0.02em] transition-colors duration-150 focus-visible:outline-none"
						>
							Frecuencia
						</button>
					</div>

					<section
						id={accessibilityPanelId}
						role="tabpanel"
						aria-labelledby={`tab-accesibilidad-${line.code.toLowerCase()}`}
						data-tab-panel="accesibilidad"
						class="pt-8"
					>
						<div class="space-y-6">
							<div class="space-y-3">
								<h2
									class="text-3xl leading-none font-semibold tracking-[-0.05em] text-[#1b1816] sm:text-4xl"
								>
									Accesibilidad
								</h2>
								<p
									class="max-w-[32rem] text-pretty text-base leading-7 text-[#544b43] sm:text-lg"
								>
									Estado actual de ascensores y escaleras en cada
									estación de la línea.
								</p>
							</div>

							<ol class="relative ml-0 list-none pl-0">
								{
									line.stations.map((station, stationIndex) => (
										<li class="relative py-3 pl-12">
											{stationIndex > 0 && (
												<span
													aria-hidden="true"
													class="pointer-events-none absolute left-[18px] top-0 h-[24px] w-[3px] rounded-full"
													style={`background-color: ${withAlpha(line.color, 0.32)};`}
												></span>
											)}
											{stationIndex < line.stations.length - 1 && (
												<span
													aria-hidden="true"
													class="pointer-events-none absolute bottom-0 left-[18px] top-[24px] w-[3px] rounded-full"
													style={`background-color: ${withAlpha(line.color, 0.32)};`}
												></span>
											)}
											<div class="flex w-full items-start gap-3 text-left">
												<span
													aria-hidden="true"
													class={`pointer-events-none absolute left-[10px] top-[15px] z-10 block h-[18px] w-[18px] rounded-full border-[2px] border-[#2f241d] ${getStatusFillClass(
														station.state,
													)}`}
												></span>
												<span class="min-w-0 flex-1">
													<span class="block text-[1.02rem] leading-[1.15] font-semibold text-[#1b1816]">
														{station.nombreEstacion}
													</span>
													<span class="mt-1.5 flex flex-wrap items-center justify-between gap-x-3 gap-y-2 text-[0.86rem] leading-[1.25] text-[#544b43]">
														{station.accessibility ? (
															<>
																<span class="font-medium text-[#544b43]">
																	{getAccessibilityStateLabel(
																		station.accessibility,
																	)}
																</span>
																<span class="ml-auto flex flex-wrap items-center justify-end gap-1.5">
																	{station.accessibility.devices.map((device) => (
																		<DeviceBadge
																			kind={
																				device.tipo === "escalera"
																					? "escalera"
																					: "ascensor"
																			}
																			isAvailable={isDeviceAvailable(
																				device.estado,
																			)}
																			label={formatDeviceName(device)}
																			statusLabel={getDeviceStatusLabel(
																				device.estado,
																			)}
																		/>
																	))}
																</span>
															</>
														) : (
															<span>
																Sin ascensores ni escaleras
																registradas
															</span>
														)}
													</span>
												</span>
											</div>
										</li>
									))
								}
							</ol>
						</div>
					</section>

					<section
						id={frequencyPanelId}
						role="tabpanel"
						aria-labelledby={`tab-frecuencia-${line.code.toLowerCase()}`}
						data-tab-panel="frecuencia"
						class="pt-8"
						hidden
					>
						<div class="space-y-6">
							<div class="space-y-3">
								<h2
									class="text-3xl leading-none font-semibold tracking-[-0.05em] text-[#1b1816] sm:text-4xl"
								>
									Frecuencia
								</h2>
								{
									frequencyChange ? (
										<p
											class="max-w-[32rem] text-pretty text-base leading-7 text-[#544b43] sm:text-lg"
										>
											Comparando el promedio anual de{" "}
											<span class="font-semibold text-[#1b1816]">
												{frequencyChange.firstPeriodLabel}
											</span>{" "}
											contra{" "}
											<span class="font-semibold text-[#1b1816]">
												{frequencyChange.latestPeriodLabel}
											</span>
											, la línea tardó{" "}
											<span class="font-semibold text-[#1b1816]">
												{frequencyChange.changeLabel}
											</span>{" "}
											{frequencyChange.isBetter ? "menos" : "más"} entre
											trenes: pasó de{" "}
											{frequencyChange.firstValueLabel} a{" "}
											{frequencyChange.latestValueLabel}.
										</p>
									) : (
										<p
											class="max-w-[32rem] text-pretty text-base leading-7 text-[#544b43] sm:text-lg"
										>
											No hay serie de frecuencia disponible para esta
											línea.
										</p>
									)
								}
							</div>

							{
								frequencySeries && (
									<div class="overflow-hidden rounded-[12px] border border-[#ddd6ce] bg-white p-4 sm:p-5">
										<FrequencyChart
											series={[frequencySeries]}
											showEndLabels={false}
											title={`Frecuencia mensual de la ${line.nombreLinea}`}
											description={`Serie mensual del intervalo promedio entre trenes de la ${line.nombreLinea}. Valores más bajos indican mejor frecuencia.`}
										/>
									</div>
								)
							}
						</div>
					</section>
				</div>
			</div>
		</main>

		<div class="bg-[#faf8f5] px-4 pb-6 pt-2 text-[#544b43]">
			<SiteFooter />
		</div>

		<style>
			[data-line-tabs] [data-tab-trigger] {
				color: #544b43;
			}

			[data-line-tabs] [data-tab-trigger][data-active="true"] {
				color: var(--tab-active-ink);
			}
		</style>

		<script is:inline>
			(() => {
				const tabOrder = ["accesibilidad", "frecuencia"];
				const allowedTabs = new Set(tabOrder);

				const syncCurrentLineTabs = ({ scroll = false } = {}) => {
					const tabs = document.querySelector("[data-line-tabs]");
					if (!(tabs instanceof HTMLElement)) return;

					const triggers = Array.from(
						tabs.querySelectorAll("[data-tab-trigger]"),
					).filter((trigger) => trigger instanceof HTMLButtonElement);
					const panels = Array.from(
						tabs.querySelectorAll("[data-tab-panel]"),
					).filter((panel) => panel instanceof HTMLElement);
					const lineLinks = Array.from(
						document.querySelectorAll("[data-line-link]"),
					).filter((link) => link instanceof HTMLAnchorElement);

					const getTabFromHash = () => {
						const hash = window.location.hash.replace(/^#/, "");
						return allowedTabs.has(hash) ? hash : "accesibilidad";
					};

					const syncLineLinkHashes = (tab) => {
						lineLinks.forEach((link) => {
							const url = new URL(link.href, window.location.origin);
							url.hash = tab;
							link.href = `${url.pathname}${url.hash}`;
						});
					};

					const setTab = (nextTab, { updateHistory = true } = {}) => {
						const tab = allowedTabs.has(nextTab)
							? nextTab
							: "accesibilidad";
						tabs.dataset.currentTab = tab;
						tabs.style.setProperty(
							"--tab-index",
							tab === "frecuencia" ? "1" : "0",
						);

						triggers.forEach((trigger) => {
							const isActive = trigger.dataset.tabTrigger === tab;
							trigger.dataset.active = isActive ? "true" : "false";
							trigger.setAttribute(
								"aria-selected",
								isActive ? "true" : "false",
							);
							trigger.tabIndex = isActive ? 0 : -1;
						});

						panels.forEach((panel) => {
							panel.hidden = panel.dataset.tabPanel !== tab;
						});

						syncLineLinkHashes(tab);

						if (updateHistory) {
							history.replaceState({}, "", `${window.location.pathname}#${tab}`);
						}
					};

					if (tabs.dataset.lineTabsBound !== "true") {
						tabs.dataset.lineTabsBound = "true";

						triggers.forEach((trigger) => {
							trigger.addEventListener("click", () => {
								setTab(trigger.dataset.tabTrigger ?? "accesibilidad");
							});

							trigger.addEventListener("keydown", (event) => {
								const currentIndex = tabOrder.findIndex(
									(tab) => tab === trigger.dataset.tabTrigger,
								);
								if (currentIndex === -1) return;

								let nextIndex = currentIndex;
								if (event.key === "ArrowRight") {
									nextIndex = (currentIndex + 1) % tabOrder.length;
								} else if (event.key === "ArrowLeft") {
									nextIndex =
										(currentIndex - 1 + tabOrder.length) % tabOrder.length;
								} else {
									return;
								}

								event.preventDefault();
								const nextTrigger = triggers[nextIndex];
								if (!nextTrigger) return;
								nextTrigger.focus();
								setTab(nextTrigger.dataset.tabTrigger ?? "accesibilidad");
							});
						});
					}

					const nextTab = getTabFromHash();
					setTab(nextTab, { updateHistory: false });

				};

				if (window.__subteLineTabsBound !== true) {
					window.__subteLineTabsBound = true;

					const resyncTabs = () => syncCurrentLineTabs({ scroll: true });

					document.addEventListener("astro:page-load", resyncTabs);
					window.addEventListener("pageshow", resyncTabs);
					window.addEventListener("hashchange", resyncTabs);
				}

				syncCurrentLineTabs({ scroll: Boolean(window.location.hash) });
				requestAnimationFrame(() => {
					syncCurrentLineTabs({ scroll: Boolean(window.location.hash) });
				});
			})();
		</script>
	</body>
</html>
