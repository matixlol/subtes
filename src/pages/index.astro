---
import {
    lineDHeatmap,
    meta,
    networkStations,
    stationAccessibility,
    stationHistory,
    stations,
} from "../generated/station-status";
import "../styles/global.css";

const lines = Object.values(
    stations.reduce((acc, station) => {
        const key = station.idLinea;
        const existing = acc[key];

        if (existing) {
            existing.stations.push(station);
            existing.totalEquipos += station.totalEquipos;
            existing.equiposFuncionando += station.equiposFuncionando;
            existing.equiposConFalla += station.equiposConFalla;
            return acc;
        }

        acc[key] = {
            idLinea: station.idLinea,
            nombreLinea: station.nombreLinea,
            totalEquipos: station.totalEquipos,
            equiposFuncionando: station.equiposFuncionando,
            equiposConFalla: station.equiposConFalla,
            stations: [station],
        };

        return acc;
    }, {}),
).sort((a, b) => a.idLinea - b.idLinea);

const formatTimestamp = (value) => {
    if (!value) return "sin fecha";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return value;

    return new Intl.DateTimeFormat("es-AR", {
        dateStyle: "short",
        timeStyle: "short",
    }).format(date);
};

const formatShortDate = (value) =>
    new Intl.DateTimeFormat("es-AR", {
        day: "2-digit",
        month: "short",
    }).format(new Date(`${value}T00:00:00Z`));

const formatDayCount = (value) => `${value} ${value === 1 ? "día" : "días"}`;

const monthLabels = lineDHeatmap.dates.map((date, index, dates) => {
    const current = new Date(`${date}T00:00:00Z`);
    const previous =
        index > 0 ? new Date(`${dates[index - 1]}T00:00:00Z`) : null;
    const currentKey = `${current.getUTCFullYear()}-${current.getUTCMonth()}`;
    const previousKey = previous
        ? `${previous.getUTCFullYear()}-${previous.getUTCMonth()}`
        : null;

    return currentKey === previousKey
        ? ""
        : new Intl.DateTimeFormat("es-AR", {
              month: "short",
          }).format(current);
});

const monthRanges = monthLabels.reduce((ranges, label, index) => {
    if (!label) return ranges;

    const nextIndex = monthLabels.findIndex(
        (candidate, candidateIndex) => candidateIndex > index && candidate,
    );
    const span = (nextIndex === -1 ? monthLabels.length : nextIndex) - index;

    ranges.push({
        label,
        startColumn: index + 2,
        span,
    });

    return ranges;
}, []);

const getHeatLevel = (day) => {
    if (day.totalEquipos === 0) return "none";
    if (day.outages === 0) return 0;

    const ratio = day.outages / day.totalEquipos;

    if (ratio >= 1) return 4;
    if (ratio >= 0.67) return 3;
    if (ratio >= 0.34) return 2;
    return 1;
};

const getHeatCellClass = (day) => {
    const level = getHeatLevel(day);

    if (level === "none") {
        return "bg-[var(--heat-none-bg)] text-[var(--heat-none-text)]";
    }

    if (level === 0) return "bg-[var(--heat-0)] text-transparent";
    if (level === 1) return "bg-[var(--heat-1)] text-transparent";
    if (level === 2) return "bg-[var(--heat-2)] text-transparent";
    if (level === 3) return "bg-[var(--heat-3)] text-transparent";
    return "bg-[var(--heat-4)] text-transparent";
};

const normalizeStationKey = (value) =>
    value
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/1°/g, "1")
        .replace(/–/g, "-")
        .replace(/[^a-zA-Z0-9]+/g, " ")
        .trim()
        .toLowerCase();

const stationAccessibilityByKey = new Map(
    stationAccessibility.map((station) => [
        `${normalizeStationKey(station.nombreLinea)}::${normalizeStationKey(
            station.nombreEstacion,
        )}`,
        station,
    ]),
);

const stationHistoryByMapKey = new Map(
    stationHistory.map((station) => [
        `${normalizeStationKey(station.nombreLinea)}::${normalizeStationKey(
            station.nombreEstacion,
        )}`,
        station,
    ]),
);

const lineColors = {
    "Línea A": "#00aedc",
    "Línea B": "#ee1b2c",
    "Línea C": "#0168b3",
    "Línea D": "#008066",
    "Línea E": "#6b1f7e",
    "Línea H": "#fed105",
};

const getAccessibilityState = (station) => {
    if (!station || station.total === 0) return "no-data";
    if (station.conFalla === 0 && station.fueraDeHorario === 0) return "full";
    if (station.funcionando === 0 && station.conFalla > 0) return "blocked";
    if (station.funcionando === 0 && station.fueraDeHorario > 0)
        return "off-hours";
    return "partial";
};

const getAccessibilityStateLabel = (station) => {
    const state = getAccessibilityState(station);

    if (state === "full") return "Todo funcionando";
    if (state === "blocked") return "Sin acceso ahora";
    if (state === "off-hours") return "Fuera de horario";
    if (state === "partial") return "Acceso parcial";
    return "Sin datos";
};

const getDiagramDotClass = (state) => {
    if (state === "full") return "bg-[var(--heat-0)]";
    if (state === "partial") return "bg-[var(--heat-2)]";
    if (state === "off-hours") return "bg-[#f1dfaa]";
    if (state === "blocked") return "bg-[var(--heat-4)]";
    return "bg-[var(--surface)]";
};

const getDeviceStatusLabel = (status) => {
    if (status === "funcionando") return "funciona";
    if (status === "fuera-de-horario") return "fuera de horario";
    return "con falla";
};

const getDeviceStatusClass = (status) => {
    if (status === "funcionando") return "text-[#315635]";
    if (status === "fuera-de-horario") return "text-[#7b5b18]";
    return "text-[var(--danger-text)]";
};

const formatDeviceName = (device) =>
    /ascensor|escalera/i.test(device.nombre)
        ? device.nombre
        : `${device.tipo === "ascensor" ? "Ascensor" : "Escalera"} ${device.nombre}`;

const diagramLines = Object.values(
    networkStations.reduce((acc, station) => {
        const line = acc[station.idLinea] ?? {
            idLinea: station.idLinea,
            nombreLinea: station.nombreLinea,
            color: lineColors[station.nombreLinea] ?? "var(--border-strong)",
            stations: [],
        };
        const key = `${normalizeStationKey(station.nombreLinea)}::${normalizeStationKey(
            station.nombreEstacion,
        )}`;
        const accessibility = stationAccessibilityByKey.get(key) ?? null;
        const history = stationHistoryByMapKey.get(key) ?? null;

        line.stations.push({
            ...station,
            accessibility,
            history,
            state: getAccessibilityState(accessibility),
        });
        acc[station.idLinea] = line;
        return acc;
    }, {}),
).sort((a, b) => a.idLinea - b.idLinea);

const totalNetworkStations = diagramLines.reduce(
    (count, line) => count + line.stations.length,
    0,
);

const stationsWithAccessibility = diagramLines.reduce(
    (count, line) =>
        count + line.stations.filter((station) => station.accessibility).length,
    0,
);

const getDiagramStationLabel = (station) => {
    if (!station.accessibility) {
        return `${station.nombreLinea} · ${station.nombreEstacion}: sin ascensores ni escaleras registradas`;
    }

    const historySummary = station.history
        ? ` · ${formatDayCount(station.history.daysWithAnyFailure)} con fallas en los últimos ${station.history.windowDays}`
        : "";

    return `${station.nombreLinea} · ${station.nombreEstacion}: ${getAccessibilityStateLabel(
        station.accessibility,
    )}. ${station.accessibility.funcionando}/${station.accessibility.total} equipos funcionando${historySummary}`;
};

const getStationTooltipId = (station) =>
    `station-tooltip-${station.idLinea}-${station.stationOrder}`;
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Estado de accesibilidad del subte</title>
    </head>
    <body class="bg-[var(--bg)] text-[var(--text)]">
        <main
            class="mx-auto w-[min(1280px,calc(100%-32px))] px-0 py-5 max-[780px]:w-[min(100%-16px,100%)] max-[780px]:pt-3 max-[780px]:pb-8"
        >
            <header
                class="flex items-end justify-between gap-6 border-b border-[var(--border)] pb-4 max-[780px]:flex-col max-[780px]:items-start max-[780px]:gap-3"
            >
                <div>
                    <h1 class="m-0 text-2xl font-semibold tracking-[-0.02em]">
                        Estado de accesibilidad
                    </h1>
                    <p class="mt-1 text-[13px] text-[var(--muted)]">
                        Último registro: {
                            formatTimestamp(meta.ultimaActualizacion)
                        }
                    </p>
                </div>
                <dl
                    class="m-0 flex gap-5 max-[780px]:flex-wrap max-[780px]:gap-4"
                    aria-label="Resumen general"
                >
                    <div class="min-w-[72px]">
                        <dt class="mb-1 text-xs text-[var(--muted)]">
                            Estaciones
                        </dt>
                        <dd class="m-0 text-xl font-semibold">
                            {meta.estaciones}
                        </dd>
                    </div>
                    <div class="min-w-[72px]">
                        <dt class="mb-1 text-xs text-[var(--muted)]">
                            Ascensores
                        </dt>
                        <dd class="m-0 text-xl font-semibold">
                            {meta.equipos}
                        </dd>
                    </div>
                    <div class="min-w-[72px]">
                        <dt class="mb-1 text-xs text-[var(--muted)]">Fallas</dt>
                        <dd class="m-0 text-xl font-semibold">
                            {meta.alertas}
                        </dd>
                    </div>
                </dl>
            </header>

            <section
                class="mt-[18px] rounded-[10px] border border-[var(--border)] bg-[var(--surface)] px-3 py-3"
                aria-labelledby="network-map-title"
            >
                <div
                    class="mb-2.5 flex items-end justify-between gap-4 max-[720px]:flex-col max-[720px]:items-start"
                >
                    <div>
                        <h2
                            id="network-map-title"
                            class="m-0 text-base leading-[1.2]"
                        >
                            Mapa por línea
                        </h2>
                        <p class="mt-1 text-[0.75rem] text-[var(--muted)]">
                            Cada fila sigue el recorrido de la línea. Pasá el
                            cursor o enfocá una estación para ver el estado
                            actual de sus ascensores y escaleras.
                        </p>
                    </div>
                    <p
                        class="m-0 whitespace-nowrap text-[0.75rem] text-[var(--muted)]"
                    >
                        {stationsWithAccessibility} de {totalNetworkStations} estaciones
                        {" "}con detalle actual
                    </p>
                </div>

                <div class="grid gap-3 [grid-template-columns:repeat(auto-fit,minmax(190px,1fr))]">
                    {
                        diagramLines.map((line) => (
                            <section class="rounded-[8px] border border-[#eee7df] px-3 py-3">
                                <div class="flex items-start gap-3">
                                    <span
                                        class="inline-flex h-7 min-w-7 items-center justify-center rounded-[8px] px-2 text-[0.8rem] font-semibold"
                                        style={`background-color: ${line.color}; color: ${
                                            line.nombreLinea === "Línea H"
                                                ? "#3a2b00"
                                                : "#ffffff"
                                        };`}
                                    >
                                        {line.nombreLinea.replace("Línea ", "")}
                                    </span>
                                    <div class="min-w-0">
                                        <p class="m-0 text-[0.82rem] font-semibold leading-tight">
                                            {line.nombreLinea}
                                        </p>
                                        <p class="mt-0.5 text-[0.72rem] text-[var(--muted)]">
                                            {line.stations.length} estaciones
                                        </p>
                                    </div>
                                </div>

                                <ol class="relative mt-3 ml-0 list-none pl-0">
                                    <span
                                        class="pointer-events-none absolute bottom-3 left-[15px] top-3 w-[2px]"
                                        style={`background-color: ${line.color};`}
                                        aria-hidden="true"
                                    />
                                    {line.stations.map((station) => (
                                        <li class="relative min-h-[28px] pl-9 pr-1 py-[5px]">
                                            <button
                                                type="button"
                                                class="flex w-full cursor-help items-start justify-between gap-3 rounded-[8px] px-0 py-0 text-left text-inherit outline-none focus-visible:ring-2 focus-visible:ring-[var(--border-strong)]"
                                                title={getDiagramStationLabel(station)}
                                                aria-label={getDiagramStationLabel(station)}
                                                data-station-tooltip={getStationTooltipId(
                                                    station,
                                                )}
                                            >
                                                <span
                                                    class={`pointer-events-none absolute left-[8px] top-[10px] z-10 block h-4 w-4 rounded-full border-[1.5px] ${getDiagramDotClass(
                                                        station.state,
                                                    )}`}
                                                    style={`border-color: ${line.color};`}
                                                />
                                                <span class="block min-w-0 text-[0.74rem] leading-[1.2] text-[var(--text)]">
                                                    {station.nombreEstacion}
                                                </span>
                                                {station.accessibility && (
                                                    <span class="whitespace-nowrap text-[0.66rem] leading-[1.2] text-[var(--muted)]">
                                                        {station.accessibility.funcionando}/
                                                        {station.accessibility.total}
                                                    </span>
                                                )}
                                            </button>

                                            <template
                                                id={getStationTooltipId(station)}
                                            >
                                                <div class="w-[280px] rounded-[8px] border border-[var(--border)] bg-[var(--surface)] px-3 py-3 text-left shadow-[0_8px_20px_rgba(47,36,29,0.12)]">
                                                    <p class="m-0 text-[0.68rem] text-[var(--muted)]">
                                                        {line.nombreLinea}
                                                    </p>
                                                    <p class="mt-1 text-[0.88rem] font-semibold leading-tight text-[var(--text)]">
                                                        {station.nombreEstacion}
                                                    </p>

                                                    {station.accessibility ? (
                                                        <>
                                                            <p class="mt-1 text-[0.75rem] text-[var(--muted)]">
                                                                {getAccessibilityStateLabel(
                                                                    station.accessibility,
                                                                )}{" "}
                                                                ·{" "}
                                                                {station.accessibility.funcionando}/
                                                                {
                                                                    station.accessibility
                                                                        .total
                                                                }{" "}
                                                                equipos funcionando
                                                            </p>

                                                            <ul class="m-0 mt-2 list-none space-y-1 border-t border-[#eee7df] pt-2 pl-0 text-[0.74rem] text-[var(--text)]">
                                                                {station.accessibility.devices.map(
                                                                    (device) => (
                                                                        <li class="flex items-start justify-between gap-3">
                                                                            <span class="leading-[1.3]">
                                                                                {formatDeviceName(
                                                                                    device,
                                                                                )}
                                                                            </span>
                                                                            <span
                                                                                class={`whitespace-nowrap text-right ${getDeviceStatusClass(
                                                                                    device.estado,
                                                                                )}`}
                                                                            >
                                                                                {getDeviceStatusLabel(
                                                                                    device.estado,
                                                                                )}
                                                                            </span>
                                                                        </li>
                                                                    ),
                                                                )}
                                                            </ul>

                                                            <div class="mt-2 border-t border-[#eee7df] pt-2 text-[0.72rem] leading-[1.35] text-[var(--muted)]">
                                                                {station.history && (
                                                                    <span class="block">
                                                                        Últimos{" "}
                                                                        {
                                                                            station
                                                                                .history
                                                                                .windowDays
                                                                        }{" "}
                                                                        días:{" "}
                                                                        {formatDayCount(
                                                                            station
                                                                                .history
                                                                                .daysWithAnyFailure,
                                                                        )}{" "}
                                                                        con fallas
                                                                    </span>
                                                                )}
                                                                <span class="block">
                                                                    Actualizado:{" "}
                                                                    {formatTimestamp(
                                                                        station
                                                                            .accessibility
                                                                            .ultimaActualizacion,
                                                                    )}
                                                                </span>
                                                            </div>
                                                        </>
                                                    ) : (
                                                        <p class="mt-2 text-[0.75rem] leading-[1.35] text-[var(--text)]">
                                                            Esta estación no tiene
                                                            ascensores ni escaleras
                                                            registradas en el dataset
                                                            actual.
                                                        </p>
                                                    )}
                                                </div>
                                            </template>
                                        </li>
                                    ))}
                                </ol>
                            </section>
                        ))
                    }
                </div>

                <div
                    class="mt-2.5 flex flex-wrap items-center gap-1.5 text-[0.7rem] text-[var(--muted)]"
                    aria-label="Escala del mapa de estaciones"
                >
                    <div
                        class="h-2.5 w-2.5 rounded-full border border-[var(--border-strong)] bg-[var(--surface)]"
                    >
                    </div>
                    <span class="whitespace-nowrap">sin datos</span>
                    <div
                        class="h-2.5 w-2.5 rounded-full border border-[var(--heat-0)] bg-[var(--heat-0)]"
                    >
                    </div>
                    <span class="whitespace-nowrap">todo funcionando</span>
                    <div
                        class="h-2.5 w-2.5 rounded-full border border-[var(--heat-2)] bg-[var(--heat-2)]"
                    >
                    </div>
                    <span class="whitespace-nowrap">acceso parcial</span>
                    <div
                        class="h-2.5 w-2.5 rounded-full border border-[#cfb167] bg-[#f1dfaa]"
                    >
                    </div>
                    <span class="whitespace-nowrap">fuera de horario</span>
                    <div
                        class="h-2.5 w-2.5 rounded-full border border-[var(--heat-4)] bg-[var(--heat-4)]"
                    >
                    </div>
                    <span class="whitespace-nowrap">sin acceso</span>
                </div>
            </section>

            <section
                class="mt-[18px] rounded-[10px] border border-[var(--border)] bg-[var(--surface)] p-4 max-[640px]:p-3"
                aria-labelledby="linea-d-heatmap-title"
            >
                <div
                    class="mb-3 flex items-end justify-between gap-4 max-[640px]:flex-col max-[640px]:items-start"
                >
                    <div>
                        <h2
                            id="linea-d-heatmap-title"
                            class="m-0 text-base leading-[1.2]"
                        >
                            {lineDHeatmap.nombreLinea}
                        </h2>
                        <p class="mt-1 text-[0.78rem] text-[var(--muted)]">
                            Si un ascensor tuvo una falla en cualquier momento
                            entre{" "}
                            {lineDHeatmap.serviceWindow}, ese día cuenta como
                            fallado.
                        </p>
                    </div>
                    <p
                        class="mt-1 whitespace-nowrap text-[0.78rem] text-[var(--muted)]"
                    >
                        {formatShortDate(lineDHeatmap.startDate)} al{" "}
                        {formatShortDate(lineDHeatmap.endDate)}
                    </p>
                </div>

                <div class="overflow-x-auto pb-1">
                    <div
                        class="grid min-w-max auto-rows-[12px] items-center gap-1"
                        style={`grid-template-columns: 160px repeat(${lineDHeatmap.dates.length}, minmax(12px, 12px));`}
                    >
                        <div class="h-3" aria-hidden="true"></div>
                        {
                            monthRanges.map((month) => (
                                <span
                                    class="whitespace-nowrap text-[0.68rem] leading-none text-[var(--muted)] lowercase"
                                    style={`grid-column: ${month.startColumn} / span ${month.span};`}
                                >
                                    {month.label}
                                </span>
                            ))
                        }

                        {
                            lineDHeatmap.stations.map((station) => (
                                <>
                                    <div class="flex items-center justify-between gap-2 pr-2 text-[0.78rem] font-semibold whitespace-nowrap">
                                        <span>{station.nombreEstacion}</span>
                                        <span class="text-[0.68rem] font-medium text-[var(--muted)]">
                                            {station.totalEquipos}
                                        </span>
                                    </div>
                                    {station.days.map((day) => (
                                        <div
                                            class={`flex h-3 w-3 items-center justify-center ${getHeatCellClass(day)}`}
                                            title={
                                                station.totalEquipos === 0
                                                    ? `${station.nombreEstacion} · sin ascensores registrados`
                                                    : `${station.nombreEstacion} · ${formatShortDate(day.date)} · ${day.outages}/${day.totalEquipos} ascensores con falla`
                                            }
                                            aria-label={
                                                station.totalEquipos === 0
                                                    ? `${station.nombreEstacion}: sin ascensores registrados`
                                                    : `${station.nombreEstacion}, ${formatShortDate(day.date)}: ${day.outages} de ${day.totalEquipos} ascensores con falla`
                                            }
                                        >
                                            {station.totalEquipos === 0 && (
                                                <svg
                                                    class="block h-[9px] w-[9px]"
                                                    viewBox="0 0 12 12"
                                                    aria-hidden="true"
                                                >
                                                    <path
                                                        d="M3 3 9 9M9 3 3 9"
                                                        fill="none"
                                                        stroke="currentColor"
                                                        stroke-linecap="round"
                                                        stroke-width="1.5"
                                                    />
                                                </svg>
                                            )}
                                        </div>
                                    ))}
                                </>
                            ))
                        }
                    </div>
                </div>

                <div
                    class="mt-3 flex flex-wrap items-center justify-end gap-1.5 text-[0.72rem] text-[var(--muted)] max-[640px]:justify-start"
                    aria-label="Escala del mapa"
                >
                    <div
                        class="flex h-3 w-3 items-center justify-center bg-[var(--heat-none-bg)] text-[var(--heat-none-text)]"
                        aria-hidden="true"
                    >
                        <svg class="block h-[9px] w-[9px]" viewBox="0 0 12 12">
                            <path
                                d="M3 3 9 9M9 3 3 9"
                                fill="none"
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-width="1.5"></path>
                        </svg>
                    </div>
                    <span class="whitespace-nowrap">sin ascensor</span>
                    <span class="whitespace-nowrap">menos fallas</span>
                    <div class="h-3 w-3 bg-[var(--heat-0)]" aria-hidden="true">
                    </div>
                    <div class="h-3 w-3 bg-[var(--heat-1)]" aria-hidden="true">
                    </div>
                    <div class="h-3 w-3 bg-[var(--heat-2)]" aria-hidden="true">
                    </div>
                    <div class="h-3 w-3 bg-[var(--heat-3)]" aria-hidden="true">
                    </div>
                    <div class="h-3 w-3 bg-[var(--heat-4)]" aria-hidden="true">
                    </div>
                    <span class="whitespace-nowrap">más fallas</span>
                </div>
            </section>

            <section class="mt-4">
                <div class="mb-3 px-1">
                    <p class="m-0 text-[13px] text-[var(--muted)]">
                        {lines.length} líneas, con {stations.length} estaciones en
                        vista compacta.
                    </p>
                </div>

                <div
                    class="[columns:3_20rem] gap-4 max-[960px]:[columns:2_18rem] max-[640px]:columns-1"
                >
                    {
                        lines.map((line) => (
                            <section class="mb-4 break-inside-avoid rounded-[10px] border border-[var(--border)] bg-[var(--surface)]">
                                <header class="flex items-start justify-between gap-3 border-b border-[#eee7df] px-4 pt-[14px] pb-3 max-[640px]:px-3">
                                    <div>
                                        <h2 class="m-0 text-base leading-[1.2]">
                                            {line.nombreLinea}
                                        </h2>
                                        <p class="mt-1 text-xs text-[var(--muted)]">
                                            {line.stations.length} estaciones
                                        </p>
                                    </div>
                                    <dl class="m-0 grid grid-cols-2 gap-x-[10px] gap-y-0 text-right">
                                        <div>
                                            <dt class="mb-0.5 text-[0.7rem] text-[var(--muted)]">
                                                Ascensores activos
                                            </dt>
                                            <dd class="m-0 text-[0.9rem] font-bold">
                                                {line.equiposFuncionando}
                                            </dd>
                                        </div>
                                        <div>
                                            <dt class="mb-0.5 text-[0.7rem] text-[var(--muted)]">
                                                Ascensores con falla
                                            </dt>
                                            <dd class="m-0 text-[0.9rem] font-bold">
                                                {line.equiposConFalla}
                                            </dd>
                                        </div>
                                    </dl>
                                </header>

                                <ul class="m-0 list-none p-0">
                                    {line.stations.map((station) => (
                                        <li
                                            class:list={[
                                                "flex items-center justify-between gap-3 border-t border-[#f1ebe4] px-4 py-[9px] text-[0.85rem] first:border-t-0 max-[640px]:px-3",
                                                station.equiposFuncionando ===
                                                    0 &&
                                                    "bg-[var(--danger-bg)] text-[var(--danger-text)]",
                                                station.equiposFuncionando >
                                                    0 &&
                                                    station.equiposConFalla >
                                                        0 &&
                                                    "bg-[var(--warn-bg)] text-[var(--warn-text)]",
                                            ]}
                                        >
                                            <div class="flex min-w-0 items-baseline gap-2">
                                                <span class="font-semibold">
                                                    {station.nombreEstacion}
                                                </span>
                                                <span class="whitespace-nowrap text-[0.72rem] opacity-[0.82]">
                                                    {`${station.equiposFuncionando}/${station.totalEquipos}`}
                                                </span>
                                            </div>
                                            <span class="whitespace-nowrap text-[0.72rem] opacity-[0.82]">
                                                {formatTimestamp(
                                                    station.ultimaActualizacion,
                                                )}
                                            </span>
                                        </li>
                                    ))}
                                </ul>
                            </section>
                        ))
                    }
                </div>
            </section>
        </main>
        <script is:inline>
            (() => {
                const tooltip = document.createElement("div");
                tooltip.className =
                    "pointer-events-none fixed z-50 hidden max-w-[calc(100vw-16px)]";
                document.body.appendChild(tooltip);

                let activeButton = null;

                const positionTooltip = (button) => {
                    const rect = button.getBoundingClientRect();
                    const tooltipRect = tooltip.getBoundingClientRect();
                    const gap = 10;
                    const maxLeft = window.innerWidth - tooltipRect.width - 8;
                    const preferredTop = rect.top - tooltipRect.height - gap;
                    const top =
                        preferredTop >= 8 ? preferredTop : rect.bottom + gap;
                    const left = Math.min(
                        Math.max(
                            rect.left + rect.width / 2 - tooltipRect.width / 2,
                            8,
                        ),
                        maxLeft,
                    );

                    tooltip.style.top = `${top}px`;
                    tooltip.style.left = `${left}px`;
                };

                const showTooltip = (button) => {
                    const templateId = button.dataset.stationTooltip;
                    if (!templateId) return;

                    const template = document.getElementById(templateId);
                    if (!(template instanceof HTMLTemplateElement)) return;

                    tooltip.innerHTML = template.innerHTML;
                    tooltip.classList.remove("hidden");
                    activeButton = button;
                    positionTooltip(button);
                };

                const hideTooltip = (button) => {
                    if (button && activeButton !== button) return;
                    activeButton = null;
                    tooltip.classList.add("hidden");
                    tooltip.innerHTML = "";
                };

                const buttons = document.querySelectorAll(
                    "[data-station-tooltip]",
                );

                buttons.forEach((button) => {
                    button.addEventListener("mouseenter", () =>
                        showTooltip(button),
                    );
                    button.addEventListener("focus", () => showTooltip(button));
                    button.addEventListener("mouseleave", () =>
                        hideTooltip(button),
                    );
                    button.addEventListener("blur", () => hideTooltip(button));
                });

                window.addEventListener("resize", () => {
                    if (activeButton) positionTooltip(activeButton);
                });

                document.addEventListener(
                    "scroll",
                    () => {
                        if (activeButton) positionTooltip(activeButton);
                    },
                    true,
                );
            })();
        </script>
    </body>
</html>
