---
import { meta, stations } from "../generated/station-status";
import "../styles/global.css";

const formatTimestamp = (value) => {
    if (!value) return "sin fecha";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return value;

    return new Intl.DateTimeFormat("es-AR", {
        dateStyle: "short",
        timeStyle: "short",
    }).format(date);
};
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Estado de accesibilidad del subte</title>
    </head>
    <body class="bg-[var(--bg)] text-[var(--text)]">
        <main
            class="mx-auto w-[min(1280px,calc(100%-32px))] px-0 py-5 max-[780px]:w-[min(100%-16px,100%)] max-[780px]:pt-3 max-[780px]:pb-8"
        >
            <header
                class="flex items-end justify-between gap-6 border-b border-[var(--border)] pb-4 max-[780px]:flex-col max-[780px]:items-start max-[780px]:gap-3"
            >
                <div>
                    <h1 class="m-0 text-2xl font-semibold tracking-[-0.02em]">
                        Estado de accesibilidad
                    </h1>
                    <p class="mt-1 text-[13px] text-[var(--muted)]">
                        Último registro: {
                            formatTimestamp(meta.ultimaActualizacion)
                        }
                    </p>
                </div>
                <dl
                    class="m-0 flex gap-5 max-[780px]:flex-wrap max-[780px]:gap-4"
                    aria-label="Resumen general"
                >
                    <div class="min-w-[72px]">
                        <dt class="mb-1 text-xs text-[var(--muted)]">
                            Estaciones
                        </dt>
                        <dd class="m-0 text-xl font-semibold">
                            {meta.estaciones}
                        </dd>
                    </div>
                    <div class="min-w-[72px]">
                        <dt class="mb-1 text-xs text-[var(--muted)]">
                            Equipos
                        </dt>
                        <dd class="m-0 text-xl font-semibold">
                            {meta.equipos}
                        </dd>
                    </div>
                    <div class="min-w-[72px]">
                        <dt class="mb-1 text-xs text-[var(--muted)]">Fallas</dt>
                        <dd class="m-0 text-xl font-semibold">
                            {meta.alertas}
                        </dd>
                    </div>
                </dl>
            </header>

            <section
                class="mt-4 overflow-hidden rounded-[10px] border border-[var(--border)] bg-[var(--surface)]"
            >
                <div
                    class="border-b border-[var(--border)] px-4 py-3 max-[780px]:px-3"
                >
                    <p class="m-0 text-[13px] text-[var(--muted)]">
                        {stations.length} filas, una por combinación actual de línea
                        y estación.
                    </p>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full border-collapse text-sm">
                        <thead>
                            <tr>
                                <th
                                    class="whitespace-nowrap border-b border-[var(--border)] bg-[#f5f1ec] px-4 py-2.5 text-left text-xs font-semibold text-[var(--muted)] max-[780px]:px-3"
                                >
                                    Línea
                                </th>
                                <th
                                    class="whitespace-nowrap border-b border-[var(--border)] bg-[#f5f1ec] px-4 py-2.5 text-left text-xs font-semibold text-[var(--muted)] max-[780px]:px-3"
                                >
                                    Estación
                                </th>
                                <th
                                    class="whitespace-nowrap border-b border-[var(--border)] bg-[#f5f1ec] px-4 py-2.5 text-left text-xs font-semibold text-[var(--muted)] max-[780px]:px-3"
                                >
                                    Equipos
                                </th>
                                <th
                                    class="whitespace-nowrap border-b border-[var(--border)] bg-[#f5f1ec] px-4 py-2.5 text-left text-xs font-semibold text-[var(--muted)] max-[780px]:px-3"
                                >
                                    Funcionando
                                </th>
                                <th
                                    class="whitespace-nowrap border-b border-[var(--border)] bg-[#f5f1ec] px-4 py-2.5 text-left text-xs font-semibold text-[var(--muted)] max-[780px]:px-3"
                                >
                                    Con falla
                                </th>
                                <th
                                    class="whitespace-nowrap border-b border-[var(--border)] bg-[#f5f1ec] px-4 py-2.5 text-left text-xs font-semibold text-[var(--muted)] max-[780px]:px-3"
                                >
                                    Actualizado
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            {
                                stations.map((station) => (
                                    <tr
                                        class:list={[
                                            "hover:bg-[#fcfbf9]",
                                            station.equiposConFalla > 0 &&
                                                "bg-[var(--danger-bg)] text-[var(--danger-text)] hover:bg-[#f5dfda]",
                                            station.equiposConFalla === 0 &&
                                                station.equiposFueraDeHorario >
                                                    0 &&
                                                "bg-[var(--warn-bg)] text-[var(--warn-text)] hover:bg-[#f2e8d1]",
                                        ]}
                                    >
                                        <td class="w-[88px] whitespace-nowrap border-b border-[#eee7df] px-4 py-2.5 align-top font-semibold max-[780px]:px-3">
                                            {station.nombreLinea}
                                        </td>
                                        <td class="min-w-[220px] border-b border-[#eee7df] px-4 py-2.5 align-top font-medium max-[780px]:px-3">
                                            {station.nombreEstacion}
                                        </td>
                                        <td class="border-b border-[#eee7df] px-4 py-2.5 align-top max-[780px]:px-3">
                                            {station.totalEquipos}
                                        </td>
                                        <td class="border-b border-[#eee7df] px-4 py-2.5 align-top max-[780px]:px-3">
                                            {station.equiposFuncionando}
                                        </td>
                                        <td class="border-b border-[#eee7df] px-4 py-2.5 align-top max-[780px]:px-3">
                                            {station.equiposConFalla}
                                        </td>
                                        <td class="border-b border-[#eee7df] px-4 py-2.5 align-top max-[780px]:px-3">
                                            {formatTimestamp(
                                                station.ultimaActualizacion,
                                            )}
                                        </td>
                                    </tr>
                                ))
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </body>
</html>
