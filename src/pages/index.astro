---
import FrequencyChart from "../components/FrequencyChart.astro";
import { frequencyMeta, frequencySeries } from "../generated/frequency-series";
import "../styles/global.css";

const formatMonth = (value: string | null) => {
	if (!value) return "sin fecha";

	const [year, month] = value.split("-").map(Number);

	return new Intl.DateTimeFormat("es-AR", {
		month: "long",
		year: "numeric",
		timeZone: "UTC",
	}).format(new Date(Date.UTC(year, month - 1, 1)));
};
---

<main class="min-h-screen bg-[#d6d6d4] px-5 py-6 text-[#1d1a16] sm:px-8 sm:py-8">
	<div class="mx-auto flex max-w-6xl flex-col gap-8">
		<header class="space-y-3">
			<div class="inline-block border-[3px] border-[#3d7be0] bg-[#efefed] px-4 py-2">
				<h1
					class="text-[2.8rem] leading-none text-[#1b1816] sm:text-[4.75rem]"
					style='font-family: "Comic Sans MS", "Marker Felt", "Bradley Hand", cursive;'
				>
					Frecuencia
				</h1>
			</div>

			<p class="max-w-3xl text-sm leading-6 text-[#4f4740] sm:text-base">
				Intervalo promedio mensual entre trenes del subte y el premetro. Más abajo
				es mejor. Serie disponible desde {formatMonth(frequencyMeta.firstMonth)}
				hasta {formatMonth(frequencyMeta.lastMonth)}.
			</p>
		</header>

		<figure class="border border-[#e8e4dd] bg-[#f6f4ef] px-3 py-3 sm:px-5 sm:py-5">
			<FrequencyChart series={frequencySeries} />

			<figcaption class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-xs text-[#6a625a] sm:text-sm">
				<span>Fuente: <code>data/frecuencia_subte.csv</code>.</span>
				<span>El bloque gris marca la etapa de mayor disrupción por COVID.</span>
				<span>Las etiquetas del margen derecho muestran el cierre más reciente.</span>
			</figcaption>
		</figure>
	</div>
</main>
