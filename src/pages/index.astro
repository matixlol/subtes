---
import { ClientRouter } from "astro:transitions";
import LineNav from "../components/LineNav.astro";
import PostHog from "../components/posthog.astro";
import { frequencySeries } from "../generated/frequency-series";
import {
    averageEntryClosures,
    meta,
    networkStations,
    stationAccessibility,
} from "../generated/station-status";
import { diagramLines } from "../lib/line-data";
import "../styles/global.css";

const uniqueMonths = Array.from(
    new Set(
        frequencySeries
            .filter((line) => line.label !== "Premetro")
            .flatMap((line) =>
                line.points
                    .map((point) => point.month)
                    .filter((month): month is string => Boolean(month)),
            ),
    ),
).sort();

const baselineYear = uniqueMonths[0]?.slice(0, 4) ?? "2019";
const latestYear = uniqueMonths.at(-1)?.slice(0, 4) ?? baselineYear;

const averageForYear = (year: string) => {
    const values = frequencySeries
        .filter((line) => line.label !== "Premetro")
        .flatMap((line) =>
            line.points
                .filter(
                    (point) =>
                        point.value !== null &&
                        point.month.startsWith(`${year}-`),
                )
                .map((point) => point.value),
        );

    return values.reduce((sum, value) => sum + value, 0) / values.length;
};

const baselineFrequency = averageForYear(baselineYear);
const latestFrequency = averageForYear(latestYear);
const frequencyChange =
    (latestFrequency - baselineFrequency) / baselineFrequency;
const frequencyChangeLabel = new Intl.NumberFormat("es-AR", {
    style: "percent",
    minimumFractionDigits: 1,
    maximumFractionDigits: 1,
})
    .format(Math.abs(frequencyChange))
    .trim();
const frequencyVerb = frequencyChange >= 0 ? "empeoró" : "mejoró";

const totalStations = new Set(
    networkStations.map(
        (station) => `${station.idLinea}::${station.nombreEstacion}`,
    ),
).size;
const stationsWithClosedEscalera = stationAccessibility.filter((station) =>
    station.devices.some(
        (device) =>
            device.tipo === "escalera" && device.estado !== "funcionando",
    ),
).length;
const closedEscaleraShareLabel = new Intl.NumberFormat("es-AR", {
    style: "percent",
    maximumFractionDigits: 0,
})
    .format(stationsWithClosedEscalera / totalStations)
    .trim();
const averageClosedEntryShareLabel = new Intl.NumberFormat("es-AR", {
    style: "percent",
    maximumFractionDigits: 0,
})
    .format(averageEntryClosures.averageClosedEntryShare)
    .trim();
const averageClosedEntryLines = diagramLines.map((line) => {
    const lineAverage = averageEntryClosures.lines.find(
        (entry) => entry.nombreLinea === line.nombreLinea,
    );

    return {
        code: line.code,
        nombreLinea: line.nombreLinea,
        color: line.color,
        ink: line.ink,
        path: `/linea/${line.code}`,
        averageClosedEntryShareLabel: new Intl.NumberFormat("es-AR", {
            style: "percent",
            maximumFractionDigits: 0,
        })
            .format(lineAverage?.averageClosedEntryShare ?? 0)
            .trim(),
    };
});
const accessibilityUpdatedAt = meta.ultimaActualizacion;
const buenosAiresDateKey = (value: Date | string) =>
    new Intl.DateTimeFormat("en-CA", {
        timeZone: "America/Argentina/Buenos_Aires",
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
    }).format(new Date(value));
const updatedAtDate = new Date(accessibilityUpdatedAt);
const updatedAtTimeLabel = new Intl.DateTimeFormat("es-AR", {
    timeZone: "America/Argentina/Buenos_Aires",
    hour: "2-digit",
    minute: "2-digit",
    hour12: false,
}).format(updatedAtDate);
const lastUpdatedLabel =
    buenosAiresDateKey(updatedAtDate) === buenosAiresDateKey(new Date())
        ? `Última vez actualizado ${updatedAtTimeLabel}`
        : `Última vez actualizado ${new Intl.DateTimeFormat("es-AR", {
              timeZone: "America/Argentina/Buenos_Aires",
              day: "numeric",
              month: "short",
          }).format(updatedAtDate)}, ${updatedAtTimeLabel}`;
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Subte porteño</title>
        <ClientRouter />
        <PostHog />
    </head>
    <body class="bg-[#faf8f5] text-[#1d1a16]">
        <main>
            <section class="relative min-h-screen overflow-hidden bg-[#d6d6d4]">
                <div
                    class="flex min-h-screen items-center px-5 pb-52 pt-10 sm:px-8"
                >
                    <div class="mx-auto w-full max-w-200">
                        <div class="space-y-5 sm:space-y-6">
                            <p
                                class="text-balance text-[clamp(2.25rem,8vw,4rem)] leading-[0.94] font-semibold tracking-[-0.06em] text-[#1b1816]"
                            >
                                El subte porteño se está deteriorando.
                            </p>
                            <p
                                class="text-balance text-[clamp(2.25rem,8vw,4rem)] leading-[0.96] font-semibold tracking-[-0.06em] text-[#1b1816]"
                            >
                                En promedio, la frecuencia {frequencyVerb}{" "}
                                <span
                                    class="inline-block whitespace-nowrap rounded-[0.16em] bg-[#f4e4a7] px-[0.18em] pb-[0.04em] text-[#1b1816]"
                                    >{frequencyChangeLabel}</span
                                >{" "}
                                desde {baselineYear}, y ahora mismo el{" "}
                                <span
                                    class="inline-block whitespace-nowrap rounded-[0.16em] bg-[#f4d9d4] px-[0.18em] pb-[0.04em] text-[#7a241a]"
                                    >{closedEscaleraShareLabel}</span
                                >{" "}
                                de estaciones tiene alguna escalera cerrada.
                            </p>
                            <div class="space-y-0.5 pt-1">
                                <p class="text-center text-xs leading-5 text-[#544b43]">
                                    Un proyecto de{" "}
                                    <a
                                        href="https://visualizando.ar"
                                        class="underline decoration-[#544b43]/40 underline-offset-3 hover:decoration-[#544b43]"
                                        target="_blank"
                                        rel="noreferrer"
                                    >
                                        visualizando.ar
                                    </a>
                                </p>
                                <p
                                    class="text-center text-xs leading-5 text-[#544b43]"
                                >
                                    {lastUpdatedLabel}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div
                    class="absolute inset-x-0 bottom-0 px-4 pb-4 sm:px-6 sm:pb-6"
                >
                    <div class="mx-auto w-full max-w-[430px]">
                        <div
                            class="mb-4 flex flex-col items-center gap-3 text-center"
                        >
                            <p
                                class="max-w-[18rem] text-sm leading-5 text-[#544b43]"
                            >
                                Mira los datos de cada línea, o seguí leyendo
                            </p>
                            <a
                                href="#"
                                class="flex h-10 w-10 items-center justify-center rounded-full border border-[#b8ab9d] text-xl text-[#1d1a16] transition-colors duration-150 hover:bg-[#efebe4]"
                                aria-label="Seguir leyendo"
                                onclick="document.getElementById('accesibilidad').scrollIntoView({ behavior: 'smooth' }) || event?.preventDefault()"
                            >
                                ↓
                            </a>
                        </div>

                        <LineNav mode="links" />
                    </div>
                </div>
            </section>

            <section
                id="accesibilidad"
                class="min-h-screen bg-[#faf8f5] px-5 py-14 sm:px-8 sm:py-16"
            >
                <div class="mx-auto max-w-6xl">
                    <h2
                        class="text-4xl leading-none font-semibold tracking-[-0.06em] text-[#1b1816] sm:text-6xl"
                    >
                        Accesibilidad
                    </h2>
                    <p
                        class="mt-6 max-w-3xl text-pretty text-lg leading-7 text-[#544b43] sm:text-xl"
                    >
                        En un día promedio de {averageEntryClosures.year},{" "}
                        <span class="font-semibold text-[#1b1816]"
                            >{averageClosedEntryShareLabel}</span
                        >{" "}
                        de las estaciones tuvo alguna entrada cerrada
                        (escalera o ascensor).
                    </p>

                    <div class="mt-10 space-y-5">
                        {
                            averageClosedEntryLines.map((line) => (
                                <div
                                    class="flex items-center gap-4 sm:gap-6"
                                >
                                    <a
                                        href={line.path}
                                        aria-label={`Ir a ${line.nombreLinea}`}
                                        data-astro-prefetch
                                        class="line-table-link"
                                        style={`--line-button-color: ${line.color}; --line-button-ink: ${line.ink};`}
                                    >
                                        <span class="line-table-link__top">
                                            <span class="line-table-link__label"
                                                >{line.code}</span
                                            >
                                        </span>
                                    </a>

                                    <div class="min-w-0">
                                        <p
                                            class="text-3xl leading-none font-semibold tracking-[-0.06em] text-[#1b1816] sm:text-5xl"
                                        >
                                            {line.averageClosedEntryShareLabel}
                                        </p>
                                        <p
                                            class="mt-1 text-xs leading-4 text-[#544b43] sm:text-sm"
                                        >
                                            escaleras o ascensores cerrados en
                                            día promedio
                                        </p>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </section>
        </main>
    </body>
</html>

<script is:inline>
  function setupIndexTracking() {
    // Track scroll-to-content arrow clicks
    var scrollBtn = document.querySelector('[aria-label="Seguir leyendo"]');
    if (scrollBtn) {
      scrollBtn.removeEventListener('click', scrollBtn.__phScrollHandler);
      scrollBtn.__phScrollHandler = function () {
        window.posthog?.capture('scroll_to_content_clicked');
      };
      scrollBtn.addEventListener('click', scrollBtn.__phScrollHandler);
    }

    // Track line link clicks in the accessibility table
    document.querySelectorAll('.line-table-link').forEach(function (link) {
      link.removeEventListener('click', link.__phLinkHandler);
      link.__phLinkHandler = function () {
        var code = link.querySelector('.line-table-link__label')?.textContent?.trim();
        window.posthog?.capture('line_link_clicked', { line_code: code });
      };
      link.addEventListener('click', link.__phLinkHandler);
    });
  }

  document.addEventListener('DOMContentLoaded', setupIndexTracking);
  document.addEventListener('astro:page-load', setupIndexTracking);
</script>

<style>
    .line-table-link {
        --button-outline-color: #2f241d;
        display: block;
        width: 100%;
        max-width: 2.6rem;
        border: 0;
        border-radius: 8px;
        background: var(--button-outline-color);
        padding: 0;
        font: inherit;
        color: inherit;
        text-decoration: none;
    }

    .line-table-link__top {
        display: flex;
        width: 100%;
        aspect-ratio: 1;
        align-items: center;
        justify-content: center;
        border: 1.5px solid var(--button-outline-color);
        border-radius: 8px;
        background: var(--line-button-color);
        color: var(--line-button-ink);
        transform: translateY(-0.12em);
        transition:
            transform 100ms ease,
            filter 100ms ease;
    }

    .line-table-link__label {
        font-size: clamp(1.05rem, 2.3vw, 1.25rem);
        line-height: 1;
        font-weight: 700;
        letter-spacing: -0.06em;
    }

    .line-table-link:hover .line-table-link__top,
    .line-table-link:focus-visible .line-table-link__top {
        transform: translateY(-0.18em);
    }

    .line-table-link:active .line-table-link__top {
        transform: translateY(0);
    }

    .line-table-link:focus-visible {
        outline: 0;
    }
</style>
