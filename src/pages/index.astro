---
import { ClientRouter } from "astro:transitions";
import LineNav from "../components/LineNav.astro";
import PostHog from "../components/posthog.astro";
import SiteFooter from "../components/SiteFooter.astro";
import {
    averageEntryClosures,
    leastAccessibleStations2025,
    meta,
    networkStations,
    stationAccessibility,
} from "../generated/station-status";
import { frequencyChangeByLine } from "../lib/frequency-data";
import { diagramLines } from "../lib/line-data";
import {
    homeOpenGraphPath,
    homePageDescription,
    homePageTitle,
    siteName,
} from "../lib/open-graph";
import "../styles/global.css";

const totalStations = new Set(
    networkStations.map(
        (station) => `${station.idLinea}::${station.nombreEstacion}`,
    ),
).size;
const stationsWithClosedEscalera = stationAccessibility.filter((station) =>
    station.devices.some(
        (device) =>
            device.tipo === "escalera" && device.estado !== "funcionando",
    ),
).length;
const closedEscaleraShareLabel = new Intl.NumberFormat("es-AR", {
    style: "percent",
    maximumFractionDigits: 0,
})
    .format(stationsWithClosedEscalera / totalStations)
    .trim();
const averageClosedEntryShareLabel = new Intl.NumberFormat("es-AR", {
    style: "percent",
    maximumFractionDigits: 0,
})
    .format(averageEntryClosures.averageClosedEntryShare)
    .trim();
const averageClosedEntryLines = diagramLines.map((line) => {
    const lineAverage = averageEntryClosures.lines.find(
        (entry) => entry.nombreLinea === line.nombreLinea,
    );

    return {
        code: line.code,
        nombreLinea: line.nombreLinea,
        color: line.color,
        ink: line.ink,
        path: `/linea/${line.code}#accesibilidad`,
        averageClosedEntryShare: lineAverage?.averageClosedEntryShare ?? 0,
        averageClosedEntryShareLabel: new Intl.NumberFormat("es-AR", {
            style: "percent",
            maximumFractionDigits: 0,
        })
            .format(lineAverage?.averageClosedEntryShare ?? 0)
            .trim(),
    };
});
const lineMetaByName = new Map(
    diagramLines.map((line) => [
        line.nombreLinea,
        {
            code: line.code,
            color: line.color,
            ink: line.ink,
            path: `/linea/${line.code}#accesibilidad`,
        },
    ]),
);
const leastAccessibleStations = leastAccessibleStations2025.stations.map(
    (station) => {
        const line = lineMetaByName.get(station.nombreLinea);

        return {
            ...station,
            code:
                line?.code ??
                station.nombreLinea.replace("Línea ", "").trim().toUpperCase(),
            color: line?.color ?? "#b8ab9d",
            ink: line?.ink ?? "#ffffff",
            path:
                line?.path ??
                `/linea/${station.nombreLinea
                    .replace("Línea ", "")
                    .trim()
                    .toUpperCase()}#accesibilidad`,
            averageClosedEntriesShareLabel: new Intl.NumberFormat("es-AR", {
                style: "percent",
                maximumFractionDigits: 0,
            })
                .format(station.averageClosedEntriesShare)
                .trim(),
            totalEntriesLabel: new Intl.NumberFormat("es-AR").format(
                station.totalEntries,
            ),
        };
    },
);
const frequencyChangeByLineMap = new Map(
    frequencyChangeByLine.map((line) => [line.series.label, line]),
);
const lineBBase = diagramLines.find((line) => line.code === "B") ?? null;
const lineB = lineBBase
    ? {
          ...lineBBase,
          path: `/linea/${lineBBase.code}#frecuencia`,
      }
    : null;
const lineBFrequencyChange = frequencyChangeByLineMap.get("Línea B") ?? null;
const lineBFrequencyVerb = !lineBFrequencyChange
    ? "cambió"
    : lineBFrequencyChange.direction === "igual"
      ? "no cambió"
      : lineBFrequencyChange.isBetter
        ? "mejoró"
        : "empeoró";
const lineBFrequencyMagnitudeLabel =
    lineBFrequencyChange?.direction === "igual"
        ? null
        : (lineBFrequencyChange?.changeLabel.replace(/\s+(mejor|peor)$/, "") ??
          null);
const frequencyLines = diagramLines
    .map((line) => {
        const change = frequencyChangeByLineMap.get(line.nombreLinea);

        if (!change) return null;

        return {
            code: line.code,
            nombreLinea: line.nombreLinea,
            color: line.color,
            ink: line.ink,
            path: `/linea/${line.code}#frecuencia`,
            change,
            toneClass:
                change.direction === "igual"
                    ? "text-[#544b43]"
                    : change.isBetter
                      ? "text-[#1f6a43]"
                      : "text-[#9b2c24]",
        };
    })
    .filter((line): line is NonNullable<typeof line> => line !== null);
const accessibilityUpdatedAt = meta.ultimaActualizacion;
const buenosAiresDateKey = (value: Date | string) =>
    new Intl.DateTimeFormat("en-CA", {
        timeZone: "America/Argentina/Buenos_Aires",
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
    }).format(new Date(value));
const updatedAtDate = new Date(accessibilityUpdatedAt);
const updatedAtTimeLabel = new Intl.DateTimeFormat("es-AR", {
    timeZone: "America/Argentina/Buenos_Aires",
    hour: "2-digit",
    minute: "2-digit",
    hour12: false,
}).format(updatedAtDate);
const heroUpdatedLabel =
    buenosAiresDateKey(updatedAtDate) === buenosAiresDateKey(new Date())
        ? `Actualizado ${updatedAtTimeLabel}`
        : `Actualizado ${new Intl.DateTimeFormat("es-AR", {
              timeZone: "America/Argentina/Buenos_Aires",
              day: "numeric",
              month: "short",
          }).format(updatedAtDate)}, ${updatedAtTimeLabel}`;
const pageTitle = homePageTitle;
const pageDescription = homePageDescription;
const canonicalUrl = Astro.url.href;
const ogImageUrl = new URL(homeOpenGraphPath, Astro.url).toString();
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{pageTitle}</title>
        <meta name="description" content={pageDescription} />
        <link rel="canonical" href={canonicalUrl} />
        <meta property="og:type" content="website" />
        <meta property="og:locale" content="es_AR" />
        <meta property="og:site_name" content={siteName} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={ogImageUrl} />
        <meta
            property="og:image:alt"
            content="Subte roto con la palabra roto partida y el texto El subte porteño se está deteriorando."
        />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={pageDescription} />
        <meta name="twitter:image" content={ogImageUrl} />
        <meta
            name="twitter:image:alt"
            content="Subte roto con la palabra roto partida y el texto El subte porteño se está deteriorando."
        />
        <ClientRouter />
        <PostHog />
    </head>
    <body class="bg-[#faf8f5] text-[#1d1a16]">
        <main>
            <section class="relative min-h-screen overflow-hidden bg-[#d6d6d4]">
                <div class="flex min-h-screen px-5 pb-56 pt-8 sm:px-8 sm:pt-10">
                    <div
                        class="mx-auto flex w-full max-w-[46rem] flex-col justify-center"
                    >
                        <div class="space-y-0">
                            <div class="space-y-5 sm:space-y-6">
                                <h1
                                    class="max-w-[8ch] text-[clamp(4rem,17vw,8.5rem)] leading-[0.82] font-black tracking-[-0.08em] text-[#111111]"
                                >
                                    Subte{" "}
                                    <span class="whitespace-nowrap">
                                        <span
                                            class="falling-word falling-word--left inline-block touch-manipulation select-none"
                                            data-falling-word>ro</span
                                        ><span
                                            class="falling-word falling-word--right inline-block touch-manipulation select-none"
                                            data-falling-word>to</span
                                        >.
                                    </span>
                                </h1>
                                <div class="space-y-3">
                                    <p
                                        class="text-[clamp(2.2rem,9vw,4rem)] leading-[0.9] font-semibold tracking-[-0.075em] text-[#111111]"
                                    >
                                        <span class="block">
                                            Ahora mismo el{" "}
                                            <span
                                                class="inline-block whitespace-nowrap rounded-[0.14em] bg-[#f4d9d4] px-[0.16em] pb-[0.03em] text-[#7a241a]"
                                                >{
                                                    closedEscaleraShareLabel
                                                }</span
                                            >
                                        </span>
                                        <span class="block">
                                            de las estaciones
                                        </span>
                                        <span class="block">
                                            tiene alguna escalera
                                        </span>
                                        <span class="block">cerrada.</span>
                                    </p>
                                    <p
                                        class="text-sm leading-5 text-[#544b43] sm:text-base"
                                    >
                                        {heroUpdatedLabel}
                                    </p>
                                </div>
                            </div>

                            <div class="space-y-3 mt-5">
                                <p
                                    class="text-[clamp(2.2rem,9vw,4rem)] leading-[0.9] font-semibold tracking-[-0.075em] text-[#111111]"
                                >
                                    <span class="block">
                                        La frecuencia del
                                    </span>
                                    <span class="block">
                                        subte{" "}
                                        {
                                            lineB && (
                                                <a
                                                    href={lineB.path}
                                                    aria-label={`Ir a ${lineB.nombreLinea}`}
                                                    data-astro-prefetch
                                                    class="inline-line-link"
                                                    style={`--line-button-color: ${lineB.color}; --line-button-ink: ${lineB.ink};`}
                                                >
                                                    <span class="inline-line-link__top">
                                                        <span class="inline-line-link__label">
                                                            {lineB.code}
                                                        </span>
                                                    </span>
                                                </a>
                                            )
                                        }{" "}
                                        {lineBFrequencyVerb}
                                    </span>
                                    <span class="block">
                                        {
                                            lineBFrequencyMagnitudeLabel && (
                                                <>
                                                    <span class="inline-block whitespace-nowrap rounded-[0.14em] bg-[#f4e4a7] px-[0.16em] pb-[0.03em] text-[#1b1816]">
                                                        {
                                                            lineBFrequencyMagnitudeLabel
                                                        }
                                                    </span>{" "}
                                                </>
                                            )
                                        }
                                        desde{" "}
                                        {
                                            lineBFrequencyChange?.firstPeriodLabel ??
                                                "2019"
                                        }.
                                    </span>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div
                    class="absolute inset-x-0 bottom-0 px-4 pb-4 sm:px-6 sm:pb-6"
                >
                    <div class="mx-auto w-full max-w-[430px]">
                        <div
                            class="mb-4 flex flex-col items-center gap-3 text-center"
                        >
                            <p
                                class="max-w-[18rem] text-sm leading-5 text-[#544b43]"
                            >
                                Mira los datos de cada línea, o seguí leyendo
                            </p>
                            <a
                                href="#"
                                class="flex h-10 w-10 items-center justify-center rounded-full border border-[#b8ab9d] text-xl text-[#1d1a16] transition-colors duration-150 hover:bg-[#efebe4]"
                                aria-label="Seguir leyendo"
                                onclick="document.getElementById('accesibilidad').scrollIntoView({ behavior: 'smooth' }) || event?.preventDefault()"
                            >
                                ↓
                            </a>
                        </div>

                        <LineNav />
                        <p
                            class="mt-4 text-center text-xs leading-5 text-[#544b43]"
                        >
                            Un proyecto de{" "}
                            <a
                                href="https://visualizando.ar"
                                class="underline decoration-[#544b43]/40 underline-offset-3 hover:decoration-[#544b43]"
                                target="_blank"
                                rel="noreferrer"
                            >
                                visualizando.ar
                            </a>
                        </p>
                    </div>
                </div>
            </section>

            <section
                id="accesibilidad"
                class="min-h-screen sm:min-h-0! bg-[#faf8f5] px-5 py-14 sm:px-8 sm:py-16"
            >
                <div
                    class="mx-auto flex w-full max-w-6xl lg:items-center lg:justify-center"
                >
                    <div class="w-full lg:max-w-[36rem]">
                        <h2
                            class="text-4xl leading-none font-semibold tracking-[-0.06em] text-[#1b1816] sm:text-6xl"
                        >
                            Accesibilidad
                        </h2>
                        <p
                            class="mt-6 max-w-3xl text-pretty text-lg leading-7 text-[#544b43] sm:text-xl lg:max-w-[32rem]"
                        >
                            En un día promedio de {averageEntryClosures.year},{
                                " "
                            }
                            <span class="font-semibold text-[#1b1816]"
                                >{averageClosedEntryShareLabel}</span
                            >{" "}
                            de las estaciones tuvo alguna entrada cerrada (escalera
                            o ascensor).
                        </p>

                        <p
                            class="mt-4 max-w-3xl text-pretty text-lg leading-7 text-[#544b43] sm:text-xl lg:max-w-[32rem]"
                        >
                            Escaleras o ascensores cerrados en un día promedio
                            de {averageEntryClosures.year}:
                        </p>

                        <div class="mt-4 space-y-5">
                            {
                                averageClosedEntryLines.map((line) => (
                                    <a
                                        href={line.path}
                                        aria-label={`Ir a ${line.nombreLinea}`}
                                        data-astro-prefetch
                                        data-line-row
                                        data-line-code={line.code}
                                        data-line-section="accesibilidad"
                                        class="line-summary-row group flex items-start gap-4 text-left text-inherit no-underline sm:gap-6"
                                    >
                                        <span
                                            class="line-table-link shrink-0"
                                            style={`--line-button-color: ${line.color}; --line-button-ink: ${line.ink};`}
                                        >
                                            <span class="line-table-link__top">
                                                <span class="line-table-link__label">
                                                    {line.code}
                                                </span>
                                            </span>
                                        </span>

                                        <span class="min-w-0 flex-1">
                                            <span>
                                                <span class="text-2xl leading-none font-semibold tracking-[-0.06em] text-[#1b1816]">
                                                    {
                                                        line.averageClosedEntryShareLabel
                                                    }
                                                </span>
                                            </span>
                                            <span class="mt-1 block h-2 w-full overflow-hidden rounded-full bg-[#ded7cf]">
                                                <span
                                                    class="block h-full rounded-full"
                                                    style={`width: ${Math.max(0, Math.min(100, line.averageClosedEntryShare * 100))}%; background-color: ${line.color};`}
                                                />
                                            </span>
                                        </span>

                                        <span
                                            aria-hidden="true"
                                            class="mt-1 shrink-0 text-[#544b43]"
                                        >
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                viewBox="0 0 16 16"
                                                fill="none"
                                                class="h-4 w-4"
                                            >
                                                <path
                                                    d="M6 3.5L10.5 8L6 12.5"
                                                    stroke="currentColor"
                                                    stroke-width="1.6"
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                />
                                            </svg>
                                        </span>
                                    </a>
                                ))
                            }
                        </div>

                        <div class="mt-8 border-t border-[#d8cec3] pt-8">
                            <h3
                                class="text-2xl leading-none font-semibold tracking-[-0.06em] text-[#1b1816] sm:text-3xl"
                            >
                                Top 5 menos accesibles de {
                                    leastAccessibleStations2025.year
                                }
                            </h3>
                            <p
                                class="mt-3 max-w-3xl text-pretty text-base leading-6 text-[#544b43] sm:text-lg"
                            >
                                Según el % promedio de entradas cerradas en
                                2025.
                            </p>

                            <ol class="mt-5 space-y-3">
                                {
                                    leastAccessibleStations.map((station) => (
                                        <li>
                                            <a
                                                href={station.path}
                                                aria-label={`Ir a ${station.nombreLinea}, ${station.nombreEstacion}`}
                                                data-astro-prefetch
                                                data-line-row
                                                data-line-code={station.code}
                                                data-line-section="accesibilidad-top-5"
                                                class="group flex items-start gap-3 text-left text-inherit no-underline sm:gap-4"
                                            >
                                                <span
                                                    class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-[8px] text-md leading-none font-black tracking-[-0.08em] border-2"
                                                    style={`/*background-color: ${station.color}; color: ${station.ink};`}
                                                >
                                                    {station.rank}
                                                </span>

                                                <span class="w-full">
                                                    <span class="flex items-start justify-between gap-3">
                                                        <span class="min-w-0">
                                                            <span class="flex flex-wrap items-center gap-x-2 gap-y-1 text-lg leading-5 font-semibold tracking-[-0.05em] text-[#1b1816] sm:text-xl">
                                                                <span>
                                                                    {
                                                                        station.nombreEstacion
                                                                    }
                                                                </span>
                                                                <span
                                                                    class="line-table-link line-table-link--mini"
                                                                    style={`--line-button-color: ${station.color}; --line-button-ink: ${station.ink};`}
                                                                >
                                                                    <span class="line-table-link__top">
                                                                        <span class="line-table-link__label">
                                                                            {
                                                                                station.code
                                                                            }
                                                                        </span>
                                                                    </span>
                                                                </span>
                                                            </span>
                                                            <span class="mt-0.5 block text-sm leading-5 text-[#544b43]">
                                                                de{" "}
                                                                {
                                                                    station.totalEntriesLabel
                                                                }{" "}
                                                                entradas
                                                            </span>
                                                        </span>

                                                        <span class="shrink-0 text-right">
                                                            <span class="block text-2xl leading-none font-semibold tracking-[-0.06em] text-[#1b1816] sm:text-3xl">
                                                                {
                                                                    station.averageClosedEntriesShareLabel
                                                                }
                                                            </span>
                                                        </span>
                                                    </span>
                                                    <span class="mt-1.5 block h-1.5 w-full overflow-hidden rounded-full bg-[#ddd5cc]">
                                                        <span
                                                            class="block h-full rounded-full"
                                                            style={`width: ${Math.max(0, Math.min(100, station.averageClosedEntriesShare * 100))}%; background-color: ${station.color};`}
                                                        />
                                                    </span>
                                                </span>
                                            </a>
                                        </li>
                                    ))
                                }
                            </ol>
                        </div>
                    </div>
                </div>
            </section>

            <section
                id="frecuencia"
                class="min-h-screen sm:min-h-0! bg-[#faf8f5] px-5 py-14 sm:px-8 sm:py-16"
            >
                <div
                    class="mx-auto flex w-full max-w-6xl lg:items-center lg:justify-center"
                >
                    <div class="w-full lg:max-w-[36rem]">
                        <h2
                            class="text-4xl leading-none font-semibold tracking-[-0.06em] text-[#1b1816] sm:text-6xl"
                        >
                            Frecuencia
                        </h2>
                        <p
                            class="mt-6 max-w-3xl text-pretty text-lg leading-7 text-[#544b43] sm:text-xl lg:max-w-[32rem]"
                        >
                            Compara el promedio anual de 2019 con el promedio
                            anual de 2025. Menos tiempo entre trenes significa
                            mejor frecuencia.
                        </p>

                        <div class="mt-10 space-y-5">
                            {
                                frequencyLines.map((line) => (
                                    <a
                                        href={line.path}
                                        aria-label={`Ir a ${line.nombreLinea}`}
                                        data-astro-prefetch
                                        data-line-row
                                        data-line-code={line.code}
                                        data-line-section="frecuencia"
                                        class="line-summary-row group flex items-center gap-4 text-left text-inherit no-underline sm:gap-6"
                                    >
                                        <span
                                            class="line-table-link shrink-0"
                                            style={`--line-button-color: ${line.color}; --line-button-ink: ${line.ink};`}
                                        >
                                            <span class="line-table-link__top">
                                                <span class="line-table-link__label">
                                                    {line.code}
                                                </span>
                                            </span>
                                        </span>

                                        <span class="min-w-0 flex-1">
                                            <span
                                                class={`block text-3xl leading-none font-semibold tracking-[-0.06em] sm:text-5xl ${line.toneClass}`}
                                            >
                                                {line.change.changeLabel}
                                            </span>
                                            <span class="mt-1 block text-xs leading-4 text-[#544b43] sm:text-sm">
                                                de {line.change.firstValueLabel}{" "}
                                                en{" "}
                                                {line.change.firstPeriodLabel} a{" "}
                                                {line.change.latestValueLabel}{" "}
                                                en{" "}
                                                {line.change.latestPeriodLabel}
                                            </span>
                                        </span>

                                        <span
                                            aria-hidden="true"
                                            class="shrink-0 text-[#544b43]"
                                        >
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                viewBox="0 0 16 16"
                                                fill="none"
                                                class="h-4 w-4"
                                            >
                                                <path
                                                    d="M6 3.5L10.5 8L6 12.5"
                                                    stroke="currentColor"
                                                    stroke-width="1.6"
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                />
                                            </svg>
                                        </span>
                                    </a>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </section>
        </main>
        <SiteFooter />
    </body>
</html>

<script>
    const setupFallingWords = () => {
        document.querySelectorAll("[data-falling-word]").forEach((word) => {
            if (word.dataset.fallingWordBound === "true") return;

            word.dataset.fallingWordBound = "true";

            let tapReleaseTimer;

            const restore = () => {
                window.clearTimeout(tapReleaseTimer);
                word.classList.add("is-restoring");
            };

            const fallAgain = () => {
                word.classList.remove("is-restoring");
            };

            word.addEventListener("pointerenter", (event) => {
                if (event.pointerType && event.pointerType !== "mouse") {
                    return;
                }

                restore();
            });

            word.addEventListener("pointerleave", fallAgain);

            word.addEventListener("pointerdown", (event) => {
                if (event.pointerType === "mouse") return;

                restore();
                tapReleaseTimer = window.setTimeout(fallAgain, 760);
            });

            word.addEventListener("pointercancel", fallAgain);
        });
    };

    setupFallingWords();
    document.addEventListener("astro:page-load", setupFallingWords);
</script>

<script is:inline>
    function setupIndexTracking() {
        // Track scroll-to-content arrow clicks
        var scrollBtn = document.querySelector('[aria-label="Seguir leyendo"]');
        if (scrollBtn) {
            scrollBtn.removeEventListener("click", scrollBtn.__phScrollHandler);
            scrollBtn.__phScrollHandler = function () {
                window.posthog?.capture("scroll_to_content_clicked");
            };
            scrollBtn.addEventListener("click", scrollBtn.__phScrollHandler);
        }

        // Track line-row clicks in the homepage sections
        document.querySelectorAll("[data-line-row]").forEach(function (link) {
            link.removeEventListener("click", link.__phLinkHandler);
            link.__phLinkHandler = function () {
                var code = link.getAttribute("data-line-code");
                var section = link.getAttribute("data-line-section");
                window.posthog?.capture("line_link_clicked", {
                    line_code: code,
                    section: section,
                });
            };
            link.addEventListener("click", link.__phLinkHandler);
        });
    }

    document.addEventListener("DOMContentLoaded", setupIndexTracking);
