---
import { lineDHeatmap, meta, stations } from "../generated/station-status";
import "../styles/global.css";

const lines = Object.values(
    stations.reduce((acc, station) => {
        const key = station.idLinea;
        const existing = acc[key];

        if (existing) {
            existing.stations.push(station);
            existing.totalEquipos += station.totalEquipos;
            existing.equiposFuncionando += station.equiposFuncionando;
            existing.equiposConFalla += station.equiposConFalla;
            return acc;
        }

        acc[key] = {
            idLinea: station.idLinea,
            nombreLinea: station.nombreLinea,
            totalEquipos: station.totalEquipos,
            equiposFuncionando: station.equiposFuncionando,
            equiposConFalla: station.equiposConFalla,
            stations: [station],
        };

        return acc;
    }, {}),
).sort((a, b) => a.idLinea - b.idLinea);

const formatTimestamp = (value) => {
    if (!value) return "sin fecha";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return value;

    return new Intl.DateTimeFormat("es-AR", {
        dateStyle: "short",
        timeStyle: "short",
    }).format(date);
};

const formatShortDate = (value) =>
    new Intl.DateTimeFormat("es-AR", {
        day: "2-digit",
        month: "short",
    }).format(new Date(`${value}T00:00:00Z`));

const monthLabels = lineDHeatmap.dates.map((date, index, dates) => {
    const current = new Date(`${date}T00:00:00Z`);
    const previous =
        index > 0 ? new Date(`${dates[index - 1]}T00:00:00Z`) : null;
    const currentKey = `${current.getUTCFullYear()}-${current.getUTCMonth()}`;
    const previousKey = previous
        ? `${previous.getUTCFullYear()}-${previous.getUTCMonth()}`
        : null;

    return currentKey === previousKey
        ? ""
        : new Intl.DateTimeFormat("es-AR", {
              month: "short",
          }).format(current);
});

const monthRanges = monthLabels.reduce((ranges, label, index) => {
    if (!label) return ranges;

    const nextIndex = monthLabels.findIndex(
        (candidate, candidateIndex) => candidateIndex > index && candidate,
    );
    const span = (nextIndex === -1 ? monthLabels.length : nextIndex) - index;

    ranges.push({
        label,
        startColumn: index + 2,
        span,
    });

    return ranges;
}, []);

const getHeatLevel = (day) => {
    if (day.totalEquipos === 0) return "none";
    if (day.outages === 0) return 0;

    const ratio = day.outages / day.totalEquipos;

    if (ratio >= 1) return 4;
    if (ratio >= 0.67) return 3;
    if (ratio >= 0.34) return 2;
    return 1;
};

const getHeatCellClass = (day) => {
    const level = getHeatLevel(day);

    if (level === "none") {
        return "bg-[var(--heat-none-bg)] text-[var(--heat-none-text)]";
    }

    if (level === 0) return "bg-[var(--heat-0)] text-transparent";
    if (level === 1) return "bg-[var(--heat-1)] text-transparent";
    if (level === 2) return "bg-[var(--heat-2)] text-transparent";
    if (level === 3) return "bg-[var(--heat-3)] text-transparent";
    return "bg-[var(--heat-4)] text-transparent";
};
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Estado de accesibilidad del subte</title>
    </head>
    <body class="bg-[var(--bg)] text-[var(--text)]">
        <main
            class="mx-auto w-[min(1280px,calc(100%-32px))] px-0 py-5 max-[780px]:w-[min(100%-16px,100%)] max-[780px]:pt-3 max-[780px]:pb-8"
        >
            <header
                class="flex items-end justify-between gap-6 border-b border-[var(--border)] pb-4 max-[780px]:flex-col max-[780px]:items-start max-[780px]:gap-3"
            >
                <div>
                    <h1 class="m-0 text-2xl font-semibold tracking-[-0.02em]">
                        Estado de accesibilidad
                    </h1>
                    <p class="mt-1 text-[13px] text-[var(--muted)]">
                        Último registro: {
                            formatTimestamp(meta.ultimaActualizacion)
                        }
                    </p>
                </div>
                <dl
                    class="m-0 flex gap-5 max-[780px]:flex-wrap max-[780px]:gap-4"
                    aria-label="Resumen general"
                >
                    <div class="min-w-[72px]">
                        <dt class="mb-1 text-xs text-[var(--muted)]">
                            Estaciones
                        </dt>
                        <dd class="m-0 text-xl font-semibold">
                            {meta.estaciones}
                        </dd>
                    </div>
                    <div class="min-w-[72px]">
                        <dt class="mb-1 text-xs text-[var(--muted)]">
                            Ascensores
                        </dt>
                        <dd class="m-0 text-xl font-semibold">
                            {meta.equipos}
                        </dd>
                    </div>
                    <div class="min-w-[72px]">
                        <dt class="mb-1 text-xs text-[var(--muted)]">Fallas</dt>
                        <dd class="m-0 text-xl font-semibold">
                            {meta.alertas}
                        </dd>
                    </div>
                </dl>
            </header>

            <section
                class="mt-[18px] rounded-[10px] border border-[var(--border)] bg-[var(--surface)] p-4 max-[640px]:p-3"
                aria-labelledby="linea-d-heatmap-title"
            >
                <div class="mb-3 flex items-end justify-between gap-4 max-[640px]:flex-col max-[640px]:items-start">
                    <div>
                        <h2
                            id="linea-d-heatmap-title"
                            class="m-0 text-base leading-[1.2]"
                        >
                            {lineDHeatmap.nombreLinea}
                        </h2>
                        <p class="mt-1 text-[0.78rem] text-[var(--muted)]">
                            Si un ascensor tuvo una falla en cualquier momento
                            entre{" "}
                            {lineDHeatmap.serviceWindow}, ese día cuenta como
                            fallado.
                        </p>
                    </div>
                    <p class="mt-1 whitespace-nowrap text-[0.78rem] text-[var(--muted)]">
                        {formatShortDate(lineDHeatmap.startDate)} al{" "}
                        {formatShortDate(lineDHeatmap.endDate)}
                    </p>
                </div>

                <div class="overflow-x-auto pb-1">
                    <div
                        class="grid min-w-max auto-rows-[12px] items-center gap-1"
                        style={`grid-template-columns: 160px repeat(${lineDHeatmap.dates.length}, minmax(12px, 12px));`}
                    >
                        <div class="h-3" aria-hidden="true">
                        </div>
                        {
                            monthRanges.map((month) => (
                                <span
                                    class="whitespace-nowrap text-[0.68rem] leading-none text-[var(--muted)] lowercase"
                                    style={`grid-column: ${month.startColumn} / span ${month.span};`}
                                >
                                    {month.label}
                                </span>
                            ))
                        }

                        {
                            lineDHeatmap.stations.map((station) => (
                                <>
                                    <div class="flex items-center justify-between gap-2 pr-2 text-[0.78rem] font-semibold whitespace-nowrap">
                                        <span>{station.nombreEstacion}</span>
                                        <span class="text-[0.68rem] font-medium text-[var(--muted)]">
                                            {station.totalEquipos}
                                        </span>
                                    </div>
                                    {station.days.map((day) => (
                                        <div
                                            class={`flex h-3 w-3 items-center justify-center ${getHeatCellClass(day)}`}
                                            title={
                                                station.totalEquipos === 0
                                                    ? `${station.nombreEstacion} · sin ascensores registrados`
                                                    : `${station.nombreEstacion} · ${formatShortDate(day.date)} · ${day.outages}/${day.totalEquipos} ascensores con falla`
                                            }
                                            aria-label={
                                                station.totalEquipos === 0
                                                    ? `${station.nombreEstacion}: sin ascensores registrados`
                                                    : `${station.nombreEstacion}, ${formatShortDate(day.date)}: ${day.outages} de ${day.totalEquipos} ascensores con falla`
                                            }
                                        >
                                            {station.totalEquipos === 0 && (
                                                <svg
                                                    class="block h-[9px] w-[9px]"
                                                    viewBox="0 0 12 12"
                                                    aria-hidden="true"
                                                >
                                                    <path
                                                        d="M3 3 9 9M9 3 3 9"
                                                        fill="none"
                                                        stroke="currentColor"
                                                        stroke-linecap="round"
                                                        stroke-width="1.5"
                                                    />
                                                </svg>
                                            )}
                                        </div>
                                    ))}
                                </>
                            ))
                        }
                    </div>
                </div>

                <div
                    class="mt-3 flex flex-wrap items-center justify-end gap-1.5 text-[0.72rem] text-[var(--muted)] max-[640px]:justify-start"
                    aria-label="Escala del mapa"
                >
                    <div
                        class="flex h-3 w-3 items-center justify-center bg-[var(--heat-none-bg)] text-[var(--heat-none-text)]"
                        aria-hidden="true"
                    >
                        <svg class="block h-[9px] w-[9px]" viewBox="0 0 12 12">
                            <path
                                d="M3 3 9 9M9 3 3 9"
                                fill="none"
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-width="1.5"
                            />
                        </svg>
                    </div>
                    <span class="whitespace-nowrap">sin ascensor</span>
                    <span class="whitespace-nowrap">menos fallas</span>
                    <div class="h-3 w-3 bg-[var(--heat-0)]" aria-hidden="true"></div>
                    <div class="h-3 w-3 bg-[var(--heat-1)]" aria-hidden="true"></div>
                    <div class="h-3 w-3 bg-[var(--heat-2)]" aria-hidden="true"></div>
                    <div class="h-3 w-3 bg-[var(--heat-3)]" aria-hidden="true"></div>
                    <div class="h-3 w-3 bg-[var(--heat-4)]" aria-hidden="true"></div>
                    <span class="whitespace-nowrap">más fallas</span>
                </div>
            </section>

            <section class="mt-4">
                <div class="mb-3 px-1">
                    <p class="m-0 text-[13px] text-[var(--muted)]">
                        {lines.length} líneas, con {stations.length} estaciones en
                        vista compacta.
                    </p>
                </div>

                <div class="[columns:3_20rem] gap-4 max-[960px]:[columns:2_18rem] max-[640px]:columns-1">
                    {
                        lines.map((line) => (
                            <section class="mb-4 break-inside-avoid rounded-[10px] border border-[var(--border)] bg-[var(--surface)]">
                                <header class="flex items-start justify-between gap-3 border-b border-[#eee7df] px-4 pt-[14px] pb-3 max-[640px]:px-3">
                                    <div>
                                        <h2 class="m-0 text-base leading-[1.2]">
                                            {line.nombreLinea}
                                        </h2>
                                        <p class="mt-1 text-xs text-[var(--muted)]">
                                            {line.stations.length} estaciones
                                        </p>
                                    </div>
                                    <dl class="m-0 grid grid-cols-2 gap-x-[10px] gap-y-0 text-right">
                                        <div>
                                            <dt class="mb-0.5 text-[0.7rem] text-[var(--muted)]">
                                                Ascensores activos
                                            </dt>
                                            <dd class="m-0 text-[0.9rem] font-bold">
                                                {line.equiposFuncionando}
                                            </dd>
                                        </div>
                                        <div>
                                            <dt class="mb-0.5 text-[0.7rem] text-[var(--muted)]">
                                                Ascensores con falla
                                            </dt>
                                            <dd class="m-0 text-[0.9rem] font-bold">
                                                {line.equiposConFalla}
                                            </dd>
                                        </div>
                                    </dl>
                                </header>

                                <ul class="m-0 list-none p-0">
                                    {line.stations.map((station) => (
                                        <li
                                            class:list={[
                                                "flex items-center justify-between gap-3 border-t border-[#f1ebe4] px-4 py-[9px] text-[0.85rem] first:border-t-0 max-[640px]:px-3",
                                                station.equiposFuncionando ===
                                                    0 &&
                                                    "bg-[var(--danger-bg)] text-[var(--danger-text)]",
                                                station.equiposFuncionando >
                                                    0 &&
                                                    station.equiposConFalla >
                                                        0 &&
                                                    "bg-[var(--warn-bg)] text-[var(--warn-text)]",
                                            ]}
                                        >
                                            <div class="flex min-w-0 items-baseline gap-2">
                                                <span class="font-semibold">
                                                    {station.nombreEstacion}
                                                </span>
                                                <span class="whitespace-nowrap text-[0.72rem] opacity-[0.82]">
                                                    {`${station.equiposFuncionando}/${station.totalEquipos}`}
                                                </span>
                                            </div>
                                            <span class="whitespace-nowrap text-[0.72rem] opacity-[0.82]">
                                                {formatTimestamp(
                                                    station.ultimaActualizacion,
                                                )}
                                            </span>
                                        </li>
                                    ))}
                                </ul>
                            </section>
                        ))
                    }
                </div>
            </section>
        </main>
    </body>
</html>
